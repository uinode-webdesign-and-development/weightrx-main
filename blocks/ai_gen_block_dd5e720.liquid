{% doc %}
  @prompt
    Create a job listing section with container and weightRx style. Job listing will have a filter option as well and it should be according to weightRx brand
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-job-listing-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-job-listing-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-job-listing-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 40px;
  }

  .ai-job-listing-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-weight: 700;
  }

  .ai-job-listing-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    opacity: 0.8;
  }

  .ai-job-listing-filters-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .ai-job-listing-filter-btn-{{ ai_gen_id }} {
    padding: 10px 20px;
    background-color: {{ block.settings.filter_bg_color }};
    color: {{ block.settings.filter_text_color }};
    border: 1px solid {{ block.settings.filter_border_color }};
    border-radius: {{ block.settings.filter_border_radius }}px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .ai-job-listing-filter-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.filter_hover_bg_color }};
    color: {{ block.settings.filter_hover_text_color }};
    border-color: {{ block.settings.filter_hover_border_color }};
  }

  .ai-job-listing-filter-btn-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.filter_active_bg_color }};
    color: {{ block.settings.filter_active_text_color }};
    border-color: {{ block.settings.filter_active_border_color }};
  }

  .ai-job-listing-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }

  .ai-job-listing-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg_color }};
    border: 1px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 24px;
    transition: all 0.3s ease;
    display: none;
  }

  .ai-job-listing-card-{{ ai_gen_id }}.visible {
    display: block;
  }

  .ai-job-listing-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .ai-job-listing-card-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
  }

  .ai-job-listing-card-title-{{ ai_gen_id }} {
    font-size: 20px;
    font-weight: 700;
    color: {{ block.settings.heading_color }};
    margin: 0 0 8px;
  }

  .ai-job-listing-card-badge-{{ ai_gen_id }} {
    padding: 4px 12px;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .ai-job-listing-card-location-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    margin-bottom: 12px;
  }

  .ai-job-listing-card-location-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .ai-job-listing-card-description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 20px;
    opacity: 0.9;
  }

  .ai-job-listing-card-footer-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 16px;
    border-top: 1px solid {{ block.settings.card_border_color }};
  }

  .ai-job-listing-card-type-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
  }

  .ai-job-listing-card-link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .ai-job-listing-card-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-job-listing-card-link-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
  }

  .ai-job-listing-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
    display: none;
  }

  .ai-job-listing-empty-{{ ai_gen_id }}.visible {
    display: block;
  }

  @media screen and (max-width: 768px) {
    .ai-job-listing-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-job-listing-filters-{{ ai_gen_id }} {
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: 8px;
    }

    .ai-job-listing-filter-btn-{{ ai_gen_id }} {
      white-space: nowrap;
    }
  }
{% endstyle %}

<job-listing-{{ ai_gen_id }} class="ai-job-listing-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-job-listing-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-job-listing-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-job-listing-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-job-listing-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-job-listing-filters-{{ ai_gen_id }}">
      <button class="ai-job-listing-filter-btn-{{ ai_gen_id }} active" data-filter="all">
        All Positions
      </button>
      <button class="ai-job-listing-filter-btn-{{ ai_gen_id }}" data-filter="engineering">
        Engineering
      </button>
      <button class="ai-job-listing-filter-btn-{{ ai_gen_id }}" data-filter="medical">
        Medical
      </button>
      <button class="ai-job-listing-filter-btn-{{ ai_gen_id }}" data-filter="operations">
        Operations
      </button>
      <button class="ai-job-listing-filter-btn-{{ ai_gen_id }}" data-filter="customer-success">
        Customer Success
      </button>
    </div>

    <div class="ai-job-listing-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign job_enabled_key = 'job_' | append: i | append: '_enabled'
          assign job_title_key = 'job_' | append: i | append: '_title'
          assign job_category_key = 'job_' | append: i | append: '_category'
          assign job_location_key = 'job_' | append: i | append: '_location'
          assign job_type_key = 'job_' | append: i | append: '_type'
          assign job_description_key = 'job_' | append: i | append: '_description'
          assign job_link_key = 'job_' | append: i | append: '_link'

          assign job_enabled = block.settings[job_enabled_key]
          assign job_title = block.settings[job_title_key]
          assign job_category = block.settings[job_category_key]
          assign job_location = block.settings[job_location_key]
          assign job_type = block.settings[job_type_key]
          assign job_description = block.settings[job_description_key]
          assign job_link = block.settings[job_link_key]
        %}

        {% if job_enabled %}
          <div class="ai-job-listing-card-{{ ai_gen_id }} visible" data-category="{{ job_category }}">
            <div class="ai-job-listing-card-header-{{ ai_gen_id }}">
              <div>
                <h3 class="ai-job-listing-card-title-{{ ai_gen_id }}">{{ job_title }}</h3>
                {% if job_location != blank %}
                  <div class="ai-job-listing-card-location-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <span>{{ job_location }}</span>
                  </div>
                {% endif %}
              </div>
              <span class="ai-job-listing-card-badge-{{ ai_gen_id }}">
                {% case job_category %}
                  {% when 'engineering' %}
                    Engineering
                  {% when 'medical' %}
                    Medical
                  {% when 'operations' %}
                    Operations
                  {% when 'customer-success' %}
                    Customer Success
                  {% else %}
                    General
                {% endcase %}
              </span>
            </div>

            {% if job_description != blank %}
              <div class="ai-job-listing-card-description-{{ ai_gen_id }}">
                {{ job_description }}
              </div>
            {% endif %}

            <div class="ai-job-listing-card-footer-{{ ai_gen_id }}">
              <span class="ai-job-listing-card-type-{{ ai_gen_id }}">{{ job_type }}</span>
              {% if job_link != blank %}
                <a href="{{ job_link }}" class="ai-job-listing-card-link-{{ ai_gen_id }}">
                  Apply Now
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="ai-job-listing-empty-{{ ai_gen_id }}">
      No positions found in this category.
    </div>
  </div>
</job-listing-{{ ai_gen_id }}>

<script>
  (function() {
    class JobListing{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.filterButtons = this.querySelectorAll('.ai-job-listing-filter-btn-{{ ai_gen_id }}');
        this.jobCards = this.querySelectorAll('.ai-job-listing-card-{{ ai_gen_id }}');
        this.emptyState = this.querySelector('.ai-job-listing-empty-{{ ai_gen_id }}');
        
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.filterButtons.forEach(button => {
          button.addEventListener('click', () => {
            const filter = button.getAttribute('data-filter');
            this.filterJobs(filter);
            
            this.filterButtons.forEach(btn => btn.classList.remove('active'));
            button.classList.add('active');
          });
        });
      }

      filterJobs(category) {
        let visibleCount = 0;

        this.jobCards.forEach(card => {
          const cardCategory = card.getAttribute('data-category');
          
          if (category === 'all' || cardCategory === category) {
            card.classList.add('visible');
            visibleCount++;
          } else {
            card.classList.remove('visible');
          }
        });

        if (visibleCount === 0) {
          this.emptyState.classList.add('visible');
        } else {
          this.emptyState.classList.remove('visible');
        }
      }
    }

    customElements.define('job-listing-{{ ai_gen_id }}', JobListing{{ ai_gen_id }});
  })();
</script>

