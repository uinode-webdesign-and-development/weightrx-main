<style>
  #section-{{ section.id }} .s-faq-content { position: relative; z-index: 1; overflow: hidden; }
  #section-{{ section.id }} .s-faq-bg-wrap { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; pointer-events: none; }
  #section-{{ section.id }} .s-faq-bg { width: 100%; height: 100%; object-fit: cover; display: block; }
</style>

<div class="s-faq-section" id="section-{{ section.id }}">
  <div class="section-spacing">
    <div class="container">
      <div class="s-faq-content">
        <div class="s-faq-heading">
          {%- if section.settings.tag_text != blank -%}
            <div class="s-faq-tag">{{ section.settings.tag_text }}</div>
          {%- endif -%}
          <h2 class="s-faq-title">{{ section.settings.title }}</h2>
        </div>
        
        <div class="s-faq-item-layout">
          {%- comment -%} Column Logic {%- endcomment -%}
          <div class="faq-left">
            {%- for block in section.blocks limit: 3 -%}
              <div class="faq-item" {{ block.shopify_attributes }}>
                <div class="faq-item-left">
                  <div class="faq-item-title-wrap"><h3 class="faq-item-title">{{ block.settings.question }}</h3></div>
                  <div class="faq-item-text-wrap"><p class="faq-item-text">{{ block.settings.answer }}</p></div>
                </div>
                <div class="faq-item-right">
                  <div class="faq-icon-plus"></div>
                  <div class="faq-icon-minus"></div>
                </div>
              </div>
            {%- endfor -%}
          </div>

          <div class="faq-right">
            {%- for block in section.blocks offset: 3 -%}
              <div class="faq-item" {{ block.shopify_attributes }}>
                <div class="faq-item-left">
                  <div class="faq-item-title-wrap"><h3 class="faq-item-title">{{ block.settings.question }}</h3></div>
                  <div class="faq-item-text-wrap"><p class="faq-item-text">{{ block.settings.answer }}</p></div>
                </div>
                <div class="faq-item-right">
                  <div class="faq-icon-plus"></div>
                  <div class="faq-icon-minus"></div>
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>

        <div class="s-faq-bg-wrap">
          {%- if section.settings.bg_image != blank -%}
            <img src="{{ section.settings.bg_image | image_url: width: 1600 }}" alt="{{ section.settings.bg_image.alt }}" class="s-faq-bg" />
          {%- endif -%}
        </div>
      </div>

      <div class="s-faq-bottom">
        <a href="{{ section.settings.button_url }}" class="s-faq-btn w-inline-block">
          <div>{{ section.settings.button_label }}</div>
          {%- if section.settings.button_icon != blank -%}
            <img src="{{ section.settings.button_icon | image_url: width: 30 }}" class="hero-btn-icon" />
          {%- endif -%}
        </a>
        <div class="s-faq-content-bottom">
          {%- if section.settings.trust_icon != blank -%}
            <img src="{{ section.settings.trust_icon | image_url: width: 30 }}" class="hero-icon-2" />
          {%- endif -%}
          <p class="s-faq-bottom-text">{{ section.settings.trust_text }}</p>
        </div>
      </div>
    </div>
  </div>
</div>


<script>
document.addEventListener('DOMContentLoaded', function() {
  const faqItems = document.querySelectorAll('.faq-item');

  faqItems.forEach(item => {
    // Click event on the whole item or title wrap
    item.addEventListener('click', function() {
      const textWrap = this.querySelector('.faq-item-text-wrap');
      const plusIcon = this.querySelector('.faq-icon-plus');
      const minusIcon = this.querySelector('.faq-icon-minus');
      
      // Check if already active
      const isOpen = textWrap.style.height !== '0px' && textWrap.style.height !== '';

      // Close all other items (Optional: remove this part if you want multiple open at once)
      faqItems.forEach(otherItem => {
        const otherText = otherItem.querySelector('.faq-item-text-wrap');
        const otherPlus = otherItem.querySelector('.faq-icon-plus');
        const otherMinus = otherItem.querySelector('.faq-icon-minus');
        
        otherText.style.height = '0px';
        if(otherPlus) otherPlus.style.opacity = '1';
        if(otherMinus) otherMinus.style.opacity = '0';
      });

      // Toggle current item
      if (!isOpen) {
        // scrollHeight calculate karta hai actual content ki height
        textWrap.style.height = textWrap.scrollHeight + 'px';
        if(plusIcon) plusIcon.style.opacity = '0';
        if(minusIcon) minusIcon.style.opacity = '1';
      } else {
        textWrap.style.height = '0px';
        if(plusIcon) plusIcon.style.opacity = '1';
        if(minusIcon) minusIcon.style.opacity = '0';
      }
    });
  });
});

</script>


