
<div class="service-section">
  <div class="section-spacing">
    <div class="container">
      <div class="service-thumb-wrap">

        {% if section.settings.desktop_bg != blank %}
          {{ section.settings.desktop_bg | image_url: width: 1500 | image_tag: 
            loading: 'lazy', 
            class: 'service-thumb', 
            widths: '600, 800, 1200, 1600, 2000',
            alt: section.settings.desktop_bg_alt 
          }}
        {% endif %}

        {% if section.settings.mobile_bg != blank %}
          <img
            src="{{ section.settings.mobile_bg | image_url: width: 800 }}"
            loading="lazy"
            alt="{{ section.settings.mobile_bg_alt }}"
            class="service-thumb-m"
          >
        {% endif %}

        <div class="service-content">
          <div class="service-top">
            <div class="service-top-left">
              <p class="service-tag">{{ section.settings.tag }}</p>

              <h2 class="section-title service-2">
                {{ section.settings.top_heading }}
              </h2>

              <p class="service-text">
                {{ section.settings.top_text }}
              </p>
            </div>

            <div class="service-top-right">
              <div class="service-item">
                <div class="service-item-top">
                  <h3 class="service-item-title">{{ section.settings.card_1_title }}</h3>
                  {% if section.settings.card_1_icon != blank %}
                    <img src="{{ section.settings.card_1_icon | image_url: width: 50 }}" loading="lazy" alt="" class="service-item-icon">
                  {% endif %}
                </div>

                <p class="service-item-text">{{ section.settings.card_1_text }}</p>

                <div class="service-item-bottom">
                  <div class="service-item-bottom-block">
                    <div class="service-item-bottom-content">
                      {% if section.settings.card_1_feature_1_icon != blank %}
                        <img src="{{ section.settings.card_1_feature_1_icon | image_url: width: 40 }}" loading="lazy" alt="" class="service-item-bottom-icon">
                      {% endif %}
                      <div class="text-block">{{ section.settings.card_1_feature_1_label }}</div>
                    </div>
                    <p class="service-item-bottom-text">{{ section.settings.card_1_feature_1_text }}</p>
                  </div>

                  <div class="service-item-bottom-block">
                    <div class="service-item-bottom-content">
                      {% if section.settings.card_1_feature_2_icon != blank %}
                        <img src="{{ section.settings.card_1_feature_2_icon | image_url: width: 40 }}" loading="lazy" alt="" class="service-item-bottom-icon">
                      {% endif %}
                      <div>{{ section.settings.card_1_feature_2_label }}</div>
                    </div>
                    <p class="service-item-bottom-text">{{ section.settings.card_1_feature_2_text }}</p>
                  </div>
                </div>
              </div>

              <div class="service-item _2">
                <div class="service-item-top">
                  <h3 class="service-item-title">{{ section.settings.card_2_title }}</h3>
                </div>

                <p class="service-item-text">{{ section.settings.card_2_text }}</p>

                <div class="service-item-bottom">
                  <div class="service-item-bottom-block">
                    <div class="service-item-bottom-content red">
                      {% if section.settings.card_2_feature_1_icon != blank %}
                        <img src="{{ section.settings.card_2_feature_1_icon | image_url: width: 40 }}" loading="lazy" alt="" class="service-item-bottom-icon">
                      {% endif %}
                      <div>{{ section.settings.card_2_feature_1_label }}</div>
                    </div>
                    <p class="service-item-bottom-text">{{ section.settings.card_2_feature_1_text }}</p>
                  </div>

                  <div class="service-item-bottom-block">
                    <div class="service-item-bottom-content red">
                      {% if section.settings.card_2_feature_2_icon != blank %}
                        <img src="{{ section.settings.card_2_feature_2_icon | image_url: width: 40 }}" loading="lazy" alt="" class="service-item-bottom-icon">
                      {% endif %}
                      <div>{{ section.settings.card_2_feature_2_label }}</div>
                    </div>
                    <p class="service-item-bottom-text">{{ section.settings.card_2_feature_2_text }}</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="service-bottom">
            <div class="hero-tag-4 service">
              {% if section.settings.rating_icon != blank %}
                <img src="{{ section.settings.rating_icon | image_url: width: 100 }}" loading="lazy" alt="" class="hero-tag-icon">
              {% endif %}
              <p class="hero-tag-text">{{ section.settings.rating_text }}</p>
            </div>

            <h1 class="section-title service">
              {{ section.settings.bottom_heading }}
            </h1>

            <div class="s-offer-item-wrap">
              {% for block in section.blocks %}
                {% if block.type == 'offer_item' %}
                  <div class="offer-item" {{ block.shopify_attributes }}>
                    {% if block.settings.icon != blank %}
                      <img src="{{ block.settings.icon | image_url: width: 30 }}" loading="lazy" alt="" class="offer-item-icon">
                    {% endif %}
                    <p class="offer-item-text service">{{ block.settings.text }}</p>
                  </div>
                {% endif %}
              {% endfor %}
            </div>

            <div class="service-btn-wrap">
              <a href="{{ section.settings.button_link }}" target="_blank" class="hero-btn service w-inline-block">
                <div>{{ section.settings.button_text }}</div>
                {% if section.settings.button_icon != blank %}
                  <img src="{{ section.settings.button_icon | image_url: width: 30 }}" loading="lazy" alt="" class="hero-btn-icon">
                {% endif %}
              </a>

              <div class="hero-content-bottom">
                {% if section.settings.guarantee_icon != blank %}
                  <img src="{{ section.settings.guarantee_icon | image_url: width: 40 }}" loading="lazy" alt="" class="hero-icon-2">
                {% endif %}
                <p class="hero-bottom-text">{{ section.settings.guarantee_text }}</p>
              </div>
            </div>
          </div>
        </div>

        {% if section.settings.shape_1 != blank %}
          <img src="{{ section.settings.shape_1 | image_url: width: 200 }}" loading="lazy" alt="" class="service-shape">
        {% endif %}
        {% if section.settings.shape_3 != blank %}
          <img src="{{ section.settings.shape_3 | image_url: width: 200 }}" loading="lazy" alt="" class="service-shape-3">
        {% endif %}
        {% if section.settings.shape_2 != blank %}
          <img src="{{ section.settings.shape_2 | image_url: width: 200 }}" loading="lazy" alt="" class="service-shape-2">
        {% endif %}
      </div>

      <div class="hero-btn-wrap-m">
        <a href="{{ section.settings.mobile_button_link }}" target="_blank" class="btn-blue w-inline-block">
          <div>{{ section.settings.mobile_button_text }}</div>
          {% if section.settings.mobile_button_icon != blank %}
            <img src="{{ section.settings.mobile_button_icon | image_url: width: 30 }}" loading="lazy" alt="" class="hero-btn-icon">
          {% endif %}
        </a>

        <div class="hero-content-bottom">
          {% if section.settings.mobile_guarantee_icon != blank %}
            <img src="{{ section.settings.mobile_guarantee_icon | image_url: width: 40 }}" loading="lazy" alt="" class="hero-icon-2">
          {% endif %}
          <p class="result-bottom-text">{{ section.settings.mobile_guarantee_text }}</p>
        </div>
      </div>
    </div>
  </div>
</div>
