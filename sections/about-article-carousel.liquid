{%- style -%}
  /* Section Base Styling */
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: #ffffff;
    overflow: hidden; /* Side scroll rokne ke liye */
  }

  /* Header / Typography */
  .article-container {
    max-width:1408px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .text-align-center {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 3rem;
  }

  .heading-style-h3 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .text-size-medium {
    font-size: 1.125rem;
    color: #4a4a4a;
    line-height: 1.5;
  }

  /* Swiper Container - Overflow Visible Trick */
  .carousel-articles_wrapper {
    position: relative;
    width: 100%;
  }

  .swiper.carousel-articles_cms-{{ section.id }} {
    overflow: visible !important; /* Isse slides container ke bahar dikhengi */
  }

  /* Card Styling */
  .item-carousel-articles {
    width: 320px; /* Fixed width like inspect element */
    background: #f9f9f9;
    border-radius: 24px;
    display: flex !important;
    flex-direction: column;
    height: auto;
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .item-carousel-articles_image {
    width: 100%;
    aspect-ratio: 1.5;
    overflow: hidden;
  }

  .item-carousel-articles_img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .item-carousel-articles_layout {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .item-carousel-articles_main-title {
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.4;
    color: #1a1a1a;
    margin-bottom: 2rem;
    min-height: 3.5rem;
    flex-grow: 1;
  }

  /* Black Pill Button */
  .blog_cta.w-button {
    background-color: #006bff;
    color: #ffffff;
    padding: 12px 28px;
    border-radius: 100px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    display: inline-block;
    transition: opacity 0.2s;
    width: fit-content;
    border: none;
  }

  .blog_cta.w-button:hover {
    opacity: 0.8;
  }

  /* Navigation Styling (Centered) */
  .swiper-nav-wrap {
    margin-top: 3rem;
    display: flex;
    justify-content: flex-end;
    width: 100%;
  }

  .swiper-nav {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .swiper_nav-button {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: none;
    transition: background 0.2s;
  }

  .swiper_nav-button:hover {
    background: #e5e5e5;
  }

  .swiper_nav-button.swiper-button-disabled {
    opacity: 0.3;
    cursor: default;
  }

  .swiper_nav-icon {
    width: 20px;
    height: auto;
  }

  @media screen and (max-width: 767px) {
    .item-carousel-articles {
      width: 280px;
    }
    .heading-style-h3 {
      font-size: 1.8rem;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <div class="article-container">
    
    {%- if section.settings.heading != blank or section.settings.description != blank -%}
      <div class="text-align-center">
        <h2 class="heading-style-h3">{{ section.settings.heading }}</h2>
        {%- if section.settings.description != blank -%}
          <div class="text-size-medium">{{ section.settings.description }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="carousel-articles_wrapper">
      <div class="swiper carousel-articles_cms-{{ section.id }}">
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}
            <div class="swiper-slide item-carousel-articles" {{ block.shopify_attributes }}>
              <div class="item-carousel-articles_image">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'item-carousel-articles_img' }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'item-carousel-articles_img' }}
                {%- endif -%}
              </div>

              <div class="item-carousel-articles_layout">
                <div class="item-carousel-articles_main-title">{{ block.settings.title }}</div>
                <div class="item-carousel-articles_cta-wrap">
                  <a href="{{ block.settings.link_url }}" class="button-main blog_cta w-button">
                    {{ block.settings.link_text }}
                  </a>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>

        <div class="swiper-nav-wrap">
          <div class="swiper-nav">
            <button class="swiper_nav-button prev-{{ section.id }}">
              <img src="https://cdn.prod.website-files.com/676eb86a8ca7187507487da6/68c415fc8de7c203054cbc11_Arrow_Prev.svg" alt="Prev" class="swiper_nav-icon">
            </button>
            <button class="swiper_nav-button next-{{ section.id }}">
              <img src="https://cdn.prod.website-files.com/676eb86a8ca7187507487da6/68c415fcebd2f456b997e139_Arrow-Next.svg" alt="Next" class="swiper_nav-icon">
            </button>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const swiper = new Swiper('.carousel-articles_cms-{{ section.id }}', {
      slidesPerView: "auto",
      spaceBetween: 24,
      grabCursor: true,
      loop: false,
      centeredSlides: false,
      navigation: {
        nextEl: '.next-{{ section.id }}',
        prevEl: '.prev-{{ section.id }}',
      },
      // Ensures the first slide starts exactly at the container margin
      on: {
        init: function() {
          this.update();
        }
      }
    });
  });
</script>

{% schema %}
{
  "name": "Full Width Article Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your guide to health and wellness starts here."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Total wellness starts and ends here. Browse our most popular articles below:</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "Article",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Article Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Minoxidil for Women: Does It Work?"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Button Text",
          "default": "Read More"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Full Width Article Slider",
      "blocks": [
        { "type": "article" },
        { "type": "article" },
        { "type": "article" },
        { "type": "article" }
      ]
    }
  ]
}
{% endschema %}