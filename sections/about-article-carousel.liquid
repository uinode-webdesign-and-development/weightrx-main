{%- style -%}
  /* Section Padding */
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: #ffffff;
  }

  /* Header Styling */
  .text-align-center { text-align: center; max-width: 800px; margin: 0 auto 3rem; }
  .heading-style-h3 { font-size: 2.5rem; font-weight: 700; color: #1a1a1a; margin-bottom: 1rem; line-height: 1.2; }
  .text-size-medium { font-size: 1.125rem; color: #4a4a4a; line-height: 1.5; }

  /* Swiper Core fixes for 'auto' width */
  .carousel-articles_cms-{{ section.id }} {
    overflow: visible !important; /* This allows cards to bleed to the edge */
    padding-right: 5%; /* Adds a little breathing room on the right */
  }

  .item-carousel-articles {
    width: 320px; /* Exact width from the inspected element */
    height: auto;
    background: #f9f9f9;
    border-radius: 24px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .item-carousel-articles_image {
    width: 100%;
    aspect-ratio: 1.5;
    overflow: hidden;
  }

  .item-carousel-articles_img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .item-carousel-articles_layout {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .item-carousel-articles_main-title {
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.4;
    color: #1a1a1a;
    margin-bottom: 2rem;
    flex-grow: 1;
  }

  /* Black Button - Exactly like Inspect Element */
  .blog_cta.w-button {
    background-color: #000;
    color: #fff;
    padding: 12px 24px;
    border-radius: 100px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    display: inline-block;
    transition: background-color 0.2s;
    width: fit-content;
  }

  /* Navigation Buttons */
  .swiper-nav-wrap {
    margin-top: 3rem;
    display: flex;
    justify-content: center;
  }
  .swiper-nav { display: flex; gap: 1rem; }
  
  .swiper_nav-button {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: none;
  }
  .swiper_nav-button.swiper-button-disabled { opacity: 0.3; cursor: auto; }
  .swiper_nav-icon { width: 20px; }
{%- endstyle -%}

<section class="section-{{ section.id }}-padding">
  <div class="page-width">
    
    <div class="text-align-center">
      <h2 class="heading-style-h3">{{ section.settings.heading }}</h2>
      <div class="text-size-medium">{{ section.settings.description }}</div>
    </div>

    <div class="carousel-articles_wrapper">
      <div class="swiper carousel-articles_cms-{{ section.id }}">
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}
            <div class="swiper-slide item-carousel-articles" {{ block.shopify_attributes }}>
              <div class="item-carousel-articles_image">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 600 | image_tag: class: 'item-carousel-articles_img', loading: 'lazy' }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'item-carousel-articles_img' }}
                {%- endif -%}
              </div>

              <div class="item-carousel-articles_layout">
                <div class="item-carousel-articles_main-title">{{ block.settings.title }}</div>
                <div class="item-carousel-articles_cta-wrap">
                  <a href="{{ block.settings.link_url }}" class="button-main blog_cta w-button">
                    {{ block.settings.link_text }}
                  </a>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>

        <div class="swiper-nav-wrap">
          <div class="swiper-nav">
            <button class="swiper_nav-button blog-prev-{{ section.id }}">
              <img src="https://cdn.prod.website-files.com/676eb86a8ca7187507487da6/68c415fc8de7c203054cbc11_Arrow_Prev.svg" class="swiper_nav-icon" alt="Prev">
            </button>
            <button class="swiper_nav-button blog-next-{{ section.id }}">
              <img src="https://cdn.prod.website-files.com/676eb86a8ca7187507487da6/68c415fcebd2f456b997e139_Arrow-Next.svg" class="swiper_nav-icon" alt="Next">
            </button>
          </div>
        </div>
      </div>
    </div>
    
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    new Swiper(".carousel-articles_cms-{{ section.id }}", {
      navigation: {
        nextEl: ".blog-next-{{ section.id }}",
        prevEl: ".blog-prev-{{ section.id }}",
      },
      spaceBetween: 24,
      slidesPerView: "auto", // Isse cards ki width CSS se control hogi
      freeMode: true,
      grabCursor: true,
      watchSlidesProgress: true,
    });
  });
</script>
{% schema %}
{
  "name": "Article Carousel",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your guide to health and wellness starts here."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Total wellness starts and ends here. Browse our most popular articles below:</p>"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "Article",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Article Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Article Title"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Label",
          "default": "Read More"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Article Carousel",
      "blocks": [{ "type": "article" }, { "type": "article" }, { "type": "article" }]
    }
  ]
}
{% endschema %}
