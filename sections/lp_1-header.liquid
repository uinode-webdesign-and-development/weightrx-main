{{ 'lp_1-style.css' | asset_url | stylesheet_tag: preload: true }}

{% style %}
  .p1-style {
      color: {{ section.settings.p1_color }};
      font-size: {{ section.settings.p1_size }}px;
    }
    .p2-style {
      color: {{ section.settings.p2_color }};
      font-size: {{ section.settings.p2_size }}px;
    }
    .p3-style {
      color: {{ section.settings.p3_color }};
      font-size: {{ section.settings.p3_size }}px;
    }
    .nav-top-content {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 5px;
    }
{% endstyle %}

<div class="nav-section">
  <div class="nav-top">
    <div class="nav-top-content">
      {%- if section.settings.top_logo != blank -%}
        {{ section.settings.top_logo | image_url: width: 100 | image_tag: class: 'nav-logo', loading: 'lazy' }}
      {%- endif -%}

      <p class="nav-text">
        <span class="p1-style">{{ section.settings.text_part_1 }}</span>
        <span class="p2-style">{{ section.settings.text_part_2 }}</span>
        <span class="p3-style">{{ section.settings.text_part_3 }}</span>
      </p>
    </div>
  </div>

  <div class="section-spacing">
    <div class="container">
      <div class="nav-layout">
        <div class="nav-left-wrap">
          <div class="nav-left">
            <a
              href="{{ section.settings.logo_link | default: '#' }}"
              aria-current="page"
              class="logo-wrap w-inline-block w--current"
            >
              {%- if section.settings.main_logo != blank -%}
                {{ section.settings.main_logo | image_url: width: 300 | image_tag: class: 'logo', loading: 'lazy' }}
              {%- else -%}
                {{ 'logo' | placeholder_svg_tag: 'logo placeholder' }}
              {%- endif -%}
            </a>
          </div>
        </div>

        <div class="nav-right">
          <div class="nav-menu">
            {%- if section.settings.contact_text != blank -%}
              <a href="{{ section.settings.contact_link | default: '#' }}" class="nav-link-wrap">
                {{ section.settings.contact_text }}
              </a>
            {%- endif -%}

            <a href="{{ section.settings.signin_link | default: '#' }}" class="nav-link-wrap w-inline-block">
              <div StaggerText="" class="nav-link">{{ section.settings.signin_text }}</div>
              {%- if section.settings.signin_icon != blank -%}
                {{ section.settings.signin_icon | image_url: width: 40 | image_tag: class: 'image', loading: 'lazy' }}
              {%- endif -%}
            </a>

            <div class="show-mobile">
              <a href="{{ section.settings.button_link | default: '#' }}" class="nav-btn w-inline-block">
                <div>{{ section.settings.button_text }}</div>
              </a>
            </div>
          </div>

          <div class="nav-open">
            <div class="nav-bar _1"></div>
            <div class="nav-bar _2"></div>
            <div class="nav-bar _3"></div>
          </div>

          <div class="hide-mobile">
            <a href="{{ section.settings.button_link | default: '#' }}" class="nav-btn w-inline-block">
              <div>{{ section.settings.button_text }}</div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "LP Navigation",
  "settings": [
    {
      "type": "header",
      "content": "Top Bar Content"
    },
    {
      "type": "image_picker",
      "id": "top_logo",
      "label": "Top Bar Logo"
    },
    {
      "type": "text",
      "id": "text_part_1",
      "label": "Text Part 1 (60,000+)",
      "default": "60,000+"
    },
    {
      "type": "color",
      "id": "p1_color",
      "label": "Part 1 Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "p1_size",
      "min": 8,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Part 1 Font Size",
      "default": 14
    },
    {
      "type": "text",
      "id": "text_part_2",
      "label": "Text Part 2 (lives Changed)",
      "default": " lives Changed "
    },
    {
      "type": "color",
      "id": "p2_color",
      "label": "Part 2 Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "p2_size",
      "min": 8,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Part 2 Font Size",
      "default": 14
    },
    {
      "type": "text",
      "id": "text_part_3",
      "label": "Text Part 3 (with GLP-1s)",
      "default": "with GLP-1s"
    },
    {
      "type": "color",
      "id": "p3_color",
      "label": "Part 3 Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "p3_size",
      "min": 8,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Part 3 Font Size",
      "default": 14
    },
    {
      "type": "header",
      "content": "Main Navigation"
    },
    {
      "type": "image_picker",
      "id": "main_logo",
      "label": "Main Logo"
    },
    {
      "type": "url",
      "id": "logo_link",
      "label": "Logo Redirect URL"
    },
    {
      "type": "text",
      "id": "contact_text",
      "label": "Contact Link Text",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "contact_link",
      "label": "Contact Link URL"
    },
    {
      "type": "text",
      "id": "signin_text",
      "label": "Sign In Text",
      "default": "Sign In"
    },
    {
      "type": "url",
      "id": "signin_link",
      "label": "Sign In URL"
    },
    {
      "type": "image_picker",
      "id": "signin_icon",
      "label": "Sign In Icon"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Get Started"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "LP Navigation"
    }
  ]
}
{% endschema %}
