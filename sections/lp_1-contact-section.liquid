<div id="contact" data-section-id="{{ section.id }}" class="s-contact-section">
  <div class="section-spacing">
    <div class="container">
      <div class="s-contact-layout">
        <div class="s-contact-left">
          {% if section.settings.tagline != blank %}
            <div class="s-contact-tag">{{ section.settings.tagline }}</div>
          {% endif %}

          <h2 class="s-contact-title">{{ section.settings.title }}</h2>
          <p class="s-contact-text">{{ section.settings.text }}</p>

          <div class="s-contact-item-wrap">
            {% if section.settings.email_link != blank %}
              <div class="s-contact-item">
                {% if section.settings.email_icon != blank %}
                  <img
                    loading="lazy"
                    src="{{ section.settings.email_icon | image_url: width: 24 }}"
                    alt=""
                    class="s-contact-item-icon"
                    width="100%"
                    height="auto"
                  >
                {% endif %}
                <a href="mailto:{{ section.settings.email_link }}" class="s-contact-item-text">
                  {{- section.settings.email_link -}}
                </a>
              </div>
            {% endif %}

            {% if section.settings.phone_link != blank %}
              <div class="s-contact-item">
                {% if section.settings.phone_icon != blank %}
                  <img
                    loading="lazy"
                    src="{{ section.settings.phone_icon | image_url: width: 24 }}"
                    alt=""
                    class="s-contact-item-icon"
                    width="100%"
                    height="auto"
                  >
                {% endif %}
                <a href="tel:{{ section.settings.phone_link | replace: ' ', '' }}" class="s-contact-item-text">
                  {{- section.settings.phone_link -}}
                </a>
              </div>
            {% endif %}
          </div>

          <div class="s-contact-info">{{ section.settings.form_instruction }}</div>
        </div>

        <div id="s-contact-right" class="s-contact-right">
          <div class="s-contact-us-wrap w-form">
            {% comment %}
              Plain form (not Shopify's {% form 'contact' %}). Submission is handled
              entirely by the JS below, which POSTs to the Zapier webhook. Using a
              Shopify contact form caused a SECOND, native POST to /contact (triggered
              by Shopify's captcha script calling form.submit()), which reloaded the
              page with an "Email is invalid." error on top of the Zapier success.
              A plain form with no action and no form_type input is ignored by that
              captcha script, so only the Zapier submission runs.
            {% endcomment %}
            <form class="s-contact-us" novalidate>
              <div class="s-contact-us-grid">
                <div class="s-contact-us-input-wrap">
                  <input
                    class="s-contact-us-input w-input"
                    name="contact[name]"
                    placeholder="Full name"
                    type="text"
                    id="ContactFormName-{{ section.id }}"
                    value="{% if customer %}{{ customer.name }}{% endif %}"
                  >
                </div>
                <div class="s-contact-us-input-wrap">
                  <input
                    class="s-contact-us-input w-input"
                    name="contact[phone]"
                    placeholder="Contact Number"
                    type="tel"
                    id="ContactFormPhone-{{ section.id }}"
                    value="{% if customer %}{{ customer.phone }}{% endif %}"
                  >
                </div>
              </div>

              <div class="s-contact-us-input-wrap">
                <input
                  class="s-contact-us-input w-input"
                  name="contact[email]"
                  placeholder="Email"
                  type="email"
                  id="ContactFormEmail-{{ section.id }}"
                  value="{% if customer %}{{ customer.email }}{% endif %}"
                  spellcheck="false"
                  autocapitalize="off"
                  required
                >
              </div>

              <div class="s-contact-us-textarea-wrap">
                <textarea
                  id="ContactFormMessage-{{ section.id }}"
                  name="contact[body]"
                  placeholder="Message"
                  class="s-contact-us-textarea w-input"
                ></textarea>
              </div>

              <div class="s-contact-us-btn-wrap">
                <input type="submit" class="s-contact-us-btn w-button" value="{{ section.settings.button_text }}">
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const form = document.querySelector('.s-contact-us');

    if (!form) {
      console.error('Form not found');
      return;
    }

    form.addEventListener('submit', async function (e) {
      e.preventDefault();

      const submitBtn = form.querySelector('[type="submit"]');
      const originalBtnValue = submitBtn ? submitBtn.value : null;
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.value = 'Sending...';
      }

      // Send the data as application/x-www-form-urlencoded (via URLSearchParams).
      // This is a CORS "simple request", so the browser does NOT fire a preflight
      // OPTIONS request. Zapier's catch hook does not return the
      // Access-Control-Allow-Headers required to pass a preflight, so sending JSON
      // with a "Content-Type: application/json" header gets blocked by the browser
      // before the request is ever sent (the cause of "Error submitting form.").
      const formData = new URLSearchParams({
        full_name: form.querySelector('[name="contact[name]"]').value,
        contact_number: form.querySelector('[name="contact[phone]"]').value,
        email: form.querySelector('[name="contact[email]"]').value,
        message: form.querySelector('[name="contact[body]"]').value,
      });

      try {
        const response = await fetch('https://hooks.zapier.com/hooks/catch/22998787/4y6eanl/', {
          method: 'POST',
          body: formData,
        });

        if (response.ok) {
          alert('Thank you! Your message has been sent.');
          form.reset();
        } else {
          alert('Something went wrong. Please try again.');
        }
      } catch (error) {
        console.error('Zapier Error:', error);
        alert('Error submitting form. Please try again.');
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          if (originalBtnValue !== null) submitBtn.value = originalBtnValue;
        }
      }
    });
  });
</script>

{% schema %}
{
  "name": "LP Contact Section",
  "class": "lp_1_contact_section",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Contact Us"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Questions? We're Here and Happy To Help."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "No Question Is Too Small. Our team is here to answer your questions and find the best path forward for you."
    },
    {
      "type": "image_picker",
      "id": "email_icon",
      "label": "Email Icon"
    },
    {
      "type": "text",
      "id": "email_link",
      "label": "Email Address",
      "default": "support@weightrx.com"
    },
    {
      "type": "image_picker",
      "id": "phone_icon",
      "label": "Phone Icon"
    },
    {
      "type": "text",
      "id": "phone_link",
      "label": "Phone Number",
      "default": "+1 (866) 286 4886"
    },
    {
      "type": "text",
      "id": "form_instruction",
      "label": "Form Instruction",
      "default": "Or fill out the form and our team will respond as soon as possible:"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Send Message"
    }
  ],
  "presets": [
    {
      "name": "LP Contact Section"
    }
  ]
}
{% endschema %}
