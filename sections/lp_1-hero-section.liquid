{{ 'lp_1-style.css' | asset_url | stylesheet_tag: preload: true }}

<style>
  #shopify-section-{{ section.id }} .brand-marquee-layout {
    animation: lp1-marquee var(--marquee-duration, 20s) linear infinite;
    display: flex;
    flex-shrink: 0;
  }
  @keyframes lp1-marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }
</style>
<div class="hero-section">
  <div class="section-spacing">
    <div class="container">
      <div class="hero-thumb-wrap">

        {%- if section.settings.hero_bg != blank -%}
          <img
            src="{{ section.settings.hero_bg | image_url: width: 2816 }}"
            loading="lazy"
            sizes="100vw"
            srcset="
              {{ section.settings.hero_bg | image_url: width: 500 }} 500w,
              {{ section.settings.hero_bg | image_url: width: 800 }} 800w,
              {{ section.settings.hero_bg | image_url: width: 1080 }} 1080w,
              {{ section.settings.hero_bg | image_url: width: 2816 }} 2816w
            "
            alt="{{ section.settings.hero_bg.alt | escape }}"
            class="hero-thumb"
          />
        {%- else -%}
          <img
            src="https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69b1226e03bba184d03a56f6_hero-bg.webp"
            loading="lazy"
            sizes="100vw"
            srcset="
              https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69b1226e03bba184d03a56f6_hero-bg-p-500.webp 500w,
              https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69b1226e03bba184d03a56f6_hero-bg-p-800.webp 800w,
              https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69b1226e03bba184d03a56f6_hero-bg-p-1080.webp 1080w,
              https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69b1226e03bba184d03a56f6_hero-bg.webp 2816w
            "
            alt=""
            class="hero-thumb"
          />
        {%- endif -%}

        {%- if section.settings.hero_thumb_mobile != blank -%}
          <img
            src="{{ section.settings.hero_thumb_mobile | image_url: width: 800 }}"
            loading="lazy"
            alt="{{ section.settings.hero_thumb_mobile.alt | escape }}"
            class="hero-thumb--m"
          />
        {%- else -%}
          <img
            src="https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69ab222c7ca3bbbfa05eb4d7_Frame%202147227941.webp"
            loading="lazy"
            alt=""
            class="hero-thumb--m"
          />
        {%- endif -%}

        {%- if section.settings.hero_shape != blank -%}
          <img
            src="{{ section.settings.hero_shape | image_url: width: 2458 }}"
            loading="lazy"
            sizes="100vw"
            srcset="
              {{ section.settings.hero_shape | image_url: width: 500 }} 500w,
              {{ section.settings.hero_shape | image_url: width: 800 }} 800w,
              {{ section.settings.hero_shape | image_url: width: 1080 }} 1080w,
              {{ section.settings.hero_shape | image_url: width: 1600 }} 1600w,
              {{ section.settings.hero_shape | image_url: width: 2000 }} 2000w,
              {{ section.settings.hero_shape | image_url: width: 2458 }} 2458w
            "
            alt="{{ section.settings.hero_shape.alt | escape }}"
            class="hero-shape"
          />
        {%- else -%}
          <img
            src="https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69b124884537ff6dbb7c5642_thumb-2.png"
            loading="lazy"
            sizes="100vw"
            srcset="
              https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69b124884537ff6dbb7c5642_thumb-2-p-500.png 500w,
              https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69b124884537ff6dbb7c5642_thumb-2-p-800.png 800w,
              https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69b124884537ff6dbb7c5642_thumb-2-p-1080.png 1080w,
              https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69b124884537ff6dbb7c5642_thumb-2-p-1600.png 1600w,
              https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69b124884537ff6dbb7c5642_thumb-2-p-2000.png 2000w,
              https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69b124884537ff6dbb7c5642_thumb-2.png 2458w
            "
            alt=""
            class="hero-shape"
          />
        {%- endif -%}

        {%- if section.settings.hero_shape_2 != blank -%}
          <img
            src="{{ section.settings.hero_shape_2 | image_url: width: 800 }}"
            loading="lazy"
            alt="{{ section.settings.hero_shape_2.alt | escape }}"
            class="hero-shape-2"
          />
        {%- else -%}
          <img
            src="https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69b122a44bea7538e87d07d4_upscalemedia-transformed%20(4).webp"
            loading="lazy"
            alt=""
            class="hero-shape-2"
          />
        {%- endif -%}

        <div class="hero-content">

          <div class="hero-tag">
            <p class="hero-tag-text">
              <span class="text-span-2">{{ section.settings.tag_label }}</span>
              <span class="text-span">{{ section.settings.tag_rating }}</span>
              {{ section.settings.tag_suffix }}
            </p>
            {%- if section.settings.tag_icon != blank -%}
              <img
                src="{{ section.settings.tag_icon | image_url: width: 100 }}"
                loading="lazy"
                alt="{{ section.settings.tag_icon.alt | escape }}"
                class="hero-tag-icon"
              />
            {%- else -%}
              <img
                src="https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69a93be529c95cea55756184_icon-1.svg"
                loading="lazy"
                alt=""
                class="hero-tag-icon"
              />
            {%- endif -%}
          </div>

          {%- assign em_word = section.settings.hero_title_em -%}
          {%- if em_word != blank and section.settings.hero_title contains em_word -%}
            {%- assign title_parts = section.settings.hero_title | split: em_word -%}
            <h1 class="hero-title">{{ title_parts[0] }}<em>{{ em_word }}</em>{{ title_parts[1] }}</h1>
          {%- else -%}
            <h1 class="hero-title">{{ section.settings.hero_title }}</h1>
          {%- endif -%}

          <p class="hero-text">{{ section.settings.hero_subtitle }}</p>

          <div class="offer-item-wrap">
            {%- for i in (1..3) -%}
              {%- assign text_key = 'offer_' | append: i | append: '_text' -%}
              {%- assign highlight_key = 'offer_' | append: i | append: '_highlight' -%}
              {%- assign offer_text = section.settings[text_key] -%}
              {%- assign offer_highlight = section.settings[highlight_key] -%}
              {%- if offer_text != blank -%}
                <div class="offer-item">
                  {%- if section.settings.offer_icon != blank -%}
                    <img
                      src="{{ section.settings.offer_icon | image_url: width: 100 }}"
                      loading="lazy"
                      alt="{{ section.settings.offer_icon.alt | escape }}"
                      class="offer-item-icon"
                    />
                  {%- else -%}
                    <img
                      src="https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69a93be5f5942258929c6549_icon-2.svg"
                      loading="lazy"
                      alt=""
                      class="offer-item-icon"
                    />
                  {%- endif -%}
                  <p class="offer-item-text">
                    {%- if offer_highlight != blank -%}
                      {%- assign parts = offer_text | split: offer_highlight -%}
                      {{ parts[0] }}<span class="text-span-3">{{ offer_highlight }}</span>{{ parts[1] }}
                    {%- else -%}
                      {{ offer_text }}
                    {%- endif -%}
                  </p>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>

          <div class="hero-btn-wrap hero">
            <a href="{{ section.settings.button_link }}" class="hero-btn w-inline-block">
              <div>{{ section.settings.button_text }}</div>
              {%- if section.settings.button_icon != blank -%}
                <img
                  src="{{ section.settings.button_icon | image_url: width: 100 }}"
                  loading="lazy"
                  alt="{{ section.settings.button_icon.alt | escape }}"
                  class="hero-btn-icon"
                />
              {%- else -%}
                <img
                  src="https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69a93cc8cb0fa04638aeaf11_icon-3.svg"
                  loading="lazy"
                  alt=""
                  class="hero-btn-icon"
                />
              {%- endif -%}
            </a>
            <div class="hero-content-bottom">
              {%- if section.settings.guarantee_icon != blank -%}
                <img
                  src="{{ section.settings.guarantee_icon | image_url: width: 100 }}"
                  loading="lazy"
                  alt="{{ section.settings.guarantee_icon.alt | escape }}"
                  class="hero-icon-2"
                />
              {%- else -%}
                <img
                  src="https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69a93d2f67e6f767b8c754a5_icon-4.svg"
                  loading="lazy"
                  alt=""
                  class="hero-icon-2"
                />
              {%- endif -%}
              <p class="hero-bottom-text">{{ section.settings.guarantee_text }}</p>
            </div>
          </div>

        </div>
      </div>

      <!-- Mobile CTA (duplicated for mobile layout) -->
      <div class="hero-btn-wrap-m">
        <a href="{{ section.settings.button_link }}" class="btn-blue w-inline-block">
          <div>{{ section.settings.button_text }}</div>
          {%- if section.settings.button_icon_mobile != blank -%}
            <img
              src="{{ section.settings.button_icon_mobile | image_url: width: 100 }}"
              loading="lazy"
              alt="{{ section.settings.button_icon_mobile.alt | escape }}"
              class="hero-btn-icon"
            />
          {%- else -%}
            <img
              src="https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69aa9bb30b981754d6b9d079_icon-9.svg"
              loading="lazy"
              alt=""
              class="hero-btn-icon"
            />
          {%- endif -%}
        </a>
        <div class="hero-content-bottom">
          {%- if section.settings.guarantee_icon_mobile != blank -%}
            <img
              src="{{ section.settings.guarantee_icon_mobile | image_url: width: 100 }}"
              loading="lazy"
              alt="{{ section.settings.guarantee_icon_mobile.alt | escape }}"
              class="hero-icon-2"
            />
          {%- else -%}
            <img
              src="https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69aa9bb3f0071c12a2b7bc09_icon-10.svg"
              loading="lazy"
              alt=""
              class="hero-icon-2"
            />
          {%- endif -%}
          <p class="result-bottom-text">{{ section.settings.guarantee_text }}</p>
        </div>
      </div>

      <!-- Brand Marquee -->
      <div class="brand-marquee" style="--marquee-duration: {{ section.settings.marquee_speed }}s;">
        {%- for i in (1..3) -%}
          <div class="brand-marquee-layout">
            {%- if section.settings.brand_1 != blank -%}
              <img src="{{ section.settings.brand_1 | image_url: width: 200 }}" loading="lazy" alt="{{ section.settings.brand_1.alt | escape }}" class="brand-icon" />
            {%- else -%}
              <img src="https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69a9413f871b94ddc4f61e5e_brand-1.svg" loading="lazy" alt="" class="brand-icon" />
            {%- endif -%}
            {%- if section.settings.brand_2 != blank -%}
              <img src="{{ section.settings.brand_2 | image_url: width: 200 }}" loading="lazy" alt="{{ section.settings.brand_2.alt | escape }}" class="brand-icon" />
            {%- else -%}
              <img src="https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69a94185f10ec00bcb9112f2_brand-2.svg" loading="lazy" alt="" class="brand-icon" />
            {%- endif -%}
            {%- if section.settings.brand_3 != blank -%}
              <img src="{{ section.settings.brand_3 | image_url: width: 200 }}" loading="lazy" alt="{{ section.settings.brand_3.alt | escape }}" class="brand-icon" />
            {%- else -%}
              <img src="https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69a94186bdb82a93bd9a8092_brand-3.svg" loading="lazy" alt="" class="brand-icon" />
            {%- endif -%}
            {%- if section.settings.brand_4 != blank -%}
              <img src="{{ section.settings.brand_4 | image_url: width: 200 }}" loading="lazy" alt="{{ section.settings.brand_4.alt | escape }}" class="brand-icon" />
            {%- else -%}
              <img src="https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69a9418524da41df3e2bf7f9_brand-4.svg" loading="lazy" alt="" class="brand-icon" />
            {%- endif -%}
          </div>
        {%- endfor -%}
        <div class="brand-overlay"></div>
        <div class="brand-overlay _2"></div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "LP 1 Hero Section",
  "settings": [
    {
      "type": "header",
      "content": "Background & Decorative Images"
    },
    {
      "type": "image_picker",
      "id": "hero_bg",
      "label": "Hero background image (desktop)",
      "info": "Recommended: 2816px wide. Falls back to default CDN image if left blank."
    },
    {
      "type": "image_picker",
      "id": "hero_thumb_mobile",
      "label": "Hero background image (mobile)",
      "info": "Falls back to default CDN image if left blank."
    },
    {
      "type": "image_picker",
      "id": "hero_shape",
      "label": "Hero decorative shape",
      "info": "Recommended: 2458px wide. Falls back to default CDN image if left blank."
    },
    {
      "type": "image_picker",
      "id": "hero_shape_2",
      "label": "Hero decorative shape 2",
      "info": "Falls back to default CDN image if left blank."
    },
    {
      "type": "header",
      "content": "Rating Tag"
    },
    {
      "type": "text",
      "id": "tag_label",
      "label": "Tag label",
      "default": "Rated"
    },
    {
      "type": "text",
      "id": "tag_rating",
      "label": "Tag rating (highlighted)",
      "default": "4.7/5.0"
    },
    {
      "type": "text",
      "id": "tag_suffix",
      "label": "Tag suffix text",
      "default": "''Excellent''"
    },
    {
      "type": "image_picker",
      "id": "tag_icon",
      "label": "Tag icon",
      "info": "Falls back to default CDN icon if left blank."
    },
    {
      "type": "header",
      "content": "Hero Content"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero title",
      "default": "Stop Overpaying for Prescription Weight Loss."
    },
    {
      "type": "text",
      "id": "hero_title_em",
      "label": "Title word(s) to italicise",
      "info": "Must match a word or phrase in the title exactly. This text will be wrapped in <em> tags.",
      "default": "Weight Loss."
    },
    {
      "type": "textarea",
      "id": "hero_subtitle",
      "label": "Hero subtitle",
      "default": "The same medication clinics charge $1200+ for, without insurance or appointments."
    },
    {
      "type": "header",
      "content": "Offer Items"
    },
    {
      "type": "image_picker",
      "id": "offer_icon",
      "label": "Offer item icon (shared)",
      "info": "Used for all three offer items. Falls back to default CDN icon if left blank."
    },
    {
      "type": "text",
      "id": "offer_1_text",
      "label": "Offer item 1 — full text",
      "default": "100% online, start in minutes"
    },
    {
      "type": "text",
      "id": "offer_1_highlight",
      "label": "Offer item 1 — highlighted portion",
      "info": "Must match text above exactly. This portion will be bold/coloured.",
      "default": "100% online,"
    },
    {
      "type": "text",
      "id": "offer_2_text",
      "label": "Offer item 2 — full text",
      "default": "pricing from $83/month"
    },
    {
      "type": "text",
      "id": "offer_2_highlight",
      "label": "Offer item 2 — highlighted portion",
      "default": "$83/month"
    },
    {
      "type": "text",
      "id": "offer_3_text",
      "label": "Offer item 3 — full text",
      "default": "ships IN 48 HOURS"
    },
    {
      "type": "text",
      "id": "offer_3_highlight",
      "label": "Offer item 3 — highlighted portion",
      "default": "48 HOURS"
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Get Started for $83/month"
    },
    {
      "type": "image_picker",
      "id": "button_icon",
      "label": "Button icon (desktop)",
      "info": "Arrow icon displayed inside the button. Falls back to default CDN icon if left blank."
    },
    {
      "type": "image_picker",
      "id": "button_icon_mobile",
      "label": "Button icon (mobile)",
      "info": "Falls back to default CDN icon if left blank."
    },
    {
      "type": "header",
      "content": "Guarantee Badge"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee text",
      "default": "30-day weight loss guarantee"
    },
    {
      "type": "image_picker",
      "id": "guarantee_icon",
      "label": "Guarantee icon (desktop)",
      "info": "Falls back to default CDN icon if left blank."
    },
    {
      "type": "image_picker",
      "id": "guarantee_icon_mobile",
      "label": "Guarantee icon (mobile)",
      "info": "Falls back to default CDN icon if left blank."
    },
    {
      "type": "header",
      "content": "Brand Marquee"
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "label": "Marquee scroll speed",
      "min": 5,
      "max": 60,
      "step": 1,
      "unit": "s",
      "default": 20,
      "info": "Duration of one full loop in seconds. Lower = faster, higher = slower."
    },
    {
      "type": "image_picker",
      "id": "brand_1",
      "label": "Brand logo 1",
      "info": "Falls back to default CDN logo if left blank."
    },
    {
      "type": "image_picker",
      "id": "brand_2",
      "label": "Brand logo 2",
      "info": "Falls back to default CDN logo if left blank."
    },
    {
      "type": "image_picker",
      "id": "brand_3",
      "label": "Brand logo 3",
      "info": "Falls back to default CDN logo if left blank."
    },
    {
      "type": "image_picker",
      "id": "brand_4",
      "label": "Brand logo 4",
      "info": "Falls back to default CDN logo if left blank."
    }
  ],
  "presets": [
    {
      "name": "LP 1 Hero Section"
    }
  ]
}
{% endschema %}
