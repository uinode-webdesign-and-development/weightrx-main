{%- style -%}
  #shopify-section-{{ section.id }} .section_citations {
    width: 100%;
    display: block;
    margin-bottom: 60px;
  }
  
  #shopify-section-{{ section.id }} .background-color-custom {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .padding-section-medium {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .container-main {
    width: 100%;
    max-width: 1408px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .citation_component {
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  #shopify-section-{{ section.id }} .text-size-medium {
    font-size: 1.25rem;
    line-height: 1.4;
    margin-bottom: 1.5rem;
  }

  #shopify-section-{{ section.id }} .text-weight-medium {
    font-weight: 600;
  }

  #shopify-section-{{ section.id }} .citation_rich-text {
    font-size: 1rem;
    line-height: 1.6;
  }

  #shopify-section-{{ section.id }} .citation_rich-text p {
    margin-bottom: 1rem;
  }

  #shopify-section-{{ section.id }} .pharmacy-list {
    list-style: disc;
    padding-left: 1.2rem;
    margin-top: 1rem;
  }

  #shopify-section-{{ section.id }} .pharmacy-list li {
    margin-bottom: 0.8rem;
  }

  #shopify-section-{{ section.id }} .pharmacy-list strong {
    font-weight: 700;
  }
  .container-main{
   background-color: #f4fcf6;
  }
.section_citations .container-main{
    padding: 50px 50px 80px ;
}
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .padding-section-medium {
      padding-top: 40px;
      padding-bottom: 40px;
    }
    #shopify-section-{{ section.id }} .text-size-medium {
      font-size: 1.1rem;
    }
  }
{%- endstyle -%}

<section class="section_citations">
  <div class="background-color-custom">
    <div class="padding-section-medium">
      <div class="container-main">
        <div class="citation_component">
          
          {%- if section.settings.heading != blank -%}
            <div class="text-size-medium text-weight-medium">
              {{ section.settings.heading }}
            </div>
          {%- endif -%}

          <div class="margin-bottom margin-small">
            <div class="citation_rich-text">
              {%- if section.settings.description != blank -%}
                {{ section.settings.description }}
              {%- endif -%}

              {%- if section.blocks.size > 0 -%}
                <ul class="pharmacy-list" role="list">
                  {%- for block in section.blocks -%}
                    <li {{ block.shopify_attributes }}>
                      <strong>{{ block.settings.pharmacy_name }}</strong>: {{ block.settings.pharmacy_address }}
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Pharmacy Citations",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f4fcf6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Partner pharmacy information"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description Text",
      "default": "<p>Eden utilizes a network of pharmacies including GoGoMeds, Precision, Enovex, and AbsolutePharmacy. Together, Eden’s pharmacies and provider network offer service to all 50 states and Washington, D.C..</p>"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "pharmacy",
      "name": "Pharmacy Info",
      "settings": [
        {
          "type": "text",
          "id": "pharmacy_name",
          "label": "Pharmacy Name",
          "default": "GoGoMeds"
        },
        {
          "type": "text",
          "id": "pharmacy_address",
          "label": "Pharmacy Address",
          "default": "525 Alexandria Pike, Southgate, KY 41071"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pharmacy Citations",
      "blocks": [
        {
          "type": "pharmacy",
          "settings": {
            "pharmacy_name": "GoGoMeds",
            "pharmacy_address": "525 Alexandria Pike, Southgate, KY 41071"
          }
        },
        {
          "type": "pharmacy",
          "settings": {
            "pharmacy_name": "Precision",
            "pharmacy_address": "2640 Merrick Rd, Bellmore, NY, 11710"
          }
        },
        {
          "type": "pharmacy",
          "settings": {
            "pharmacy_name": "Enovex",
            "pharmacy_address": "1111 N. Brand Blvd, Unit M, Glendale, CA 91202"
          }
        },
        {
          "type": "pharmacy",
          "settings": {
            "pharmacy_name": "AbsolutePharmacy",
            "pharmacy_address": "16011 N. Nebraska Ave., Suite 103, Lutz, FL 33549"
          }
        }
      ]
    }
  ]
}
{% endschema %}