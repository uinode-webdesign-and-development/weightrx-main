<!-- Shopify Testimonial Slider - Fixed Width & Centered Layout -->
{% style %}
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      background-color: {{ section.settings.bg_color }};
      overflow: hidden;
    }

    .testimonial_cards-component .container {
        overflow: visible;
    }

    .text-align-center { text-align: center; }
    .margin-bottom.margin-medium { margin-bottom: 2rem; }
    .margin-bottom.margin-large { margin-bottom: 3rem; }

    /* Buttons */
    .button-group.is-v2-center {
      display: flex;
      gap: 1rem;
      justify-content: center;
      align-items: center;
      flex-wrap: wrap;
    }

    .button-main {
      background: #000;
      color: #fff;
      padding: 14px 28px;
      text-decoration: none;
      border-radius: 50px;
      font-weight: 600;
      font-size: 15px;
      display: inline-block;
    }

    .button-gradient {
      padding: 14px 28px;
      border: 1px solid #ddd;
      border-radius: 50px;
      text-decoration: none;
      color: #000;
      font-weight: 600;
      background: #fff;
      font-size: 15px;
      display: inline-block;
    }

    /* Fixed Width Card Design */
    .testimonial-card {
      background: #fff;
      padding: 3rem 2rem;
      border-radius: 2.6px;
      border: 1px solid #f0f0f0;
      box-shadow: 0 4px 20px rgba(0,0,0,0.03);

      /* Center alignment */
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;

      /* Fixed height ensure uniformity */
      height: 100%;
      min-height: 420px;
      box-sizing: border-box;
      justify-content: space-between;
    }

    .testimonial-stars {
      display: flex;
      gap: 4px;
      margin-bottom: 1.5rem;
    }

    .icon-1x1-xsmall {
      width: 20px;
      height: 20px;
    }

    .testimonial-txt {
      font-size: 1.15rem;
      line-height: 1.5;
      color: #333;
      margin-bottom: 2rem;
      font-weight: 400;
      flex-grow: 1; /* Pushes author info to bottom */
      display: flex;
      align-items: center;
    }

    .author-info-wrap {
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .author-name {
      font-size: 1.1rem;
      font-weight: 700;
      color: #000;
      margin-bottom: 0.75rem;
    }

    /* Verified Badge Capsule */
    .verfied-customer {
      display: flex;
      align-items: center;
      gap: 6px;
      background: #f4f4f4;
      padding: 6px 16px;
      border-radius: 50px;
    }

    .check-icon {
      width: 16px;
      height: 16px;
      opacity: 0.6;
    }

    .vc-text {
      font-size: 0.85rem;
      color: #666;
      font-weight: 500;
    }

    /* Swiper Controls */
    .swiper-nav-wrap {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 3rem;
    }

    .swiper-nav {
      display: flex;
      gap: 12px;
    }

    .swiper_nav-button {
      width: 48px;
      height: 48px;
      border: 1px solid #000;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: 0.3s ease;
    }

    .swiper_nav-button:not(.swiper-button-disabled):hover {
      background: #000;
    }
    .swiper_nav-button:not(.swiper-button-disabled):hover img {
      filter: invert(1);
    }

    .swiper-button-disabled {
      opacity: 0.2;
      cursor: not-allowed;
    }

    .text-style-fineprint {
      font-size: 0.85rem;
      max-width: 500px;
      color: #888;
    }

    /* Swiper Slide Fix */
    .swiper.testimonials {
      width: 100%;
      overflow: visible !important;
    }

    /* desktop par card width fix rahegi */
    .swiper-slide.testimonials {
      height: auto;
      width: 380px; /* Fixed width for all cards */
    }

    @media (max-width: 480px) {
      .swiper-slide.testimonials {
        width: 290px; /* Smaller fixed width for mobile */
      }
    }

    .sr-only {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); border: 0;
    }
{% endstyle %}

<section class="section-{{ section.id }} section_testimonial-cards">
  <div class="testimonial_cards-component">
    <div class="container">
      <div class="margin-bottom margin-medium text-align-center">
        <div class="rte-style-text">
          <h2 class="heading-style-h3">{{ section.settings.heading }}</h2>
        </div>
      </div>

      <div class="margin-bottom margin-large">
        <div class="button-group is-v2-center">
          {% if section.settings.btn_1_text != blank %}
            <a href="{{ section.settings.btn_1_link }}" class="button-main">{{ section.settings.btn_1_text }}</a>
          {% endif %}
          {% if section.settings.btn_2_text != blank %}
            <a href="{{ section.settings.btn_2_link }}" class="button-gradient">{{ section.settings.btn_2_text }}</a>
          {% endif %}
        </div>
      </div>

      <div class="swiper testimonials">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            <div class="swiper-slide testimonials" {{ block.shopify_attributes }}>
              <div class="testimonial-card">
                <div class="testimonial-stars">
                  {% for i in (1..5) %}
                    <img
                      src="https://cdn.prod.website-files.com/676eb86a8ca7187507487da6/68b9f54f86ecd2c2bb2ea940_Star.svg"
                      loading="lazy"
                      alt="Star"
                      class="icon-1x1-xsmall"
                      width="100%"
                      height="auto"
                    >
                  {% endfor %}
                </div>

                <div class="testimonial-txt">
                  <span>{{ block.settings.testimonial_text }}</span>
                </div>

                <div class="author-info-wrap">
                  <div class="author-name">{{ block.settings.author_name }}</div>
                  <div class="verfied-customer">
                    <img
                      loading="lazy"
                      src="https://cdn.prod.website-files.com/676eb86a8ca7187507487da6/68b9f54f86ecd2c2bb2ea940_Star.svg"
                      style="display:none;"
                      width="100%"
                      height="auto"
                    >
                    <!-- preload check fix -->
                    <img
                      loading="lazy"
                      src="https://cdn.prod.website-files.com/676eb86a8ca7187507487da6/68b9dd124536f85dafb8f046_Check.svg"
                      alt="Verified"
                      class="check-icon"
                      width="100%"
                      height="auto"
                    >
                    <div class="vc-text">{{ section.settings.verified_text }}</div>
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

      <div class="swiper-nav-wrap">
        <div class="text-style-fineprint">
          {{ section.settings.fine_print }}
        </div>
        <div class="swiper-nav">
          <div class="swiper_nav-button test-prev">
            <img
              src="https://cdn.prod.website-files.com/676eb86a8ca7187507487da6/68c415fc8de7c203054cbc11_Arrow_Prev.svg"
              loading="lazy"
              width="20"
              height="20"
              alt="Prev"
            >
          </div>
          <div class="swiper_nav-button test-next">
            <img
              src="https://cdn.prod.website-files.com/676eb86a8ca7187507487da6/68c415fcebd2f456b997e139_Arrow-Next.svg"
              loading="lazy"
              width="20"
              height="20"
              alt="Next"
            >
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    new Swiper('.section-{{ section.id }} .swiper.testimonials', {
      speed: 500,
      slidesPerView: 'auto',
      spaceBetween: 24,
      centeredSlides: false,
      navigation: {
        nextEl: '.section-{{ section.id }} .test-next',
        prevEl: '.section-{{ section.id }} .test-prev',
      },
    });
  });
</script>

{% schema %}
{
  "name": "Testimonial Fixed Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our members love us"
    },
    {
      "type": "richtext",
      "id": "fine_print",
      "label": "Fine Print",
      "default": "<p>Individual results may vary. Testimonials reflect personal experiences.</p>"
    },
    {
      "type": "text",
      "id": "btn_1_text",
      "label": "Button 1 Text",
      "default": "Get started"
    },
    {
      "type": "url",
      "id": "btn_1_link",
      "label": "Button 1 Link"
    },
    {
      "type": "text",
      "id": "btn_2_text",
      "label": "Button 2 Text",
      "default": "See if you're eligible"
    },
    {
      "type": "url",
      "id": "btn_2_link",
      "label": "Button 2 Link"
    },
    {
      "type": "text",
      "id": "verified_text",
      "label": "Verified Badge Text",
      "default": "Verified Customer"
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f9f9f9"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "testimonial_text",
          "label": "Testimonial Content",
          "default": "“I feel healthier. I don't have constant food cravings. My energy levels have increased.”"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author Name",
          "default": "Mandy G."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonial Fixed Slider",
      "blocks": [{ "type": "testimonial" }, { "type": "testimonial" }, { "type": "testimonial" }]
    }
  ]
}
{% endschema %}
