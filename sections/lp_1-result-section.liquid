{{ 'lp_1-style.css' | asset_url | stylesheet_tag: preload: true }}

<style>
  #section-{{ section.id }} .result-marquee {
    display: flex;
    overflow: hidden;
    user-select: none;
    gap: 20px;
  }

  #section-{{ section.id }} .result-marquee-layout {
    flex-shrink: 0;
    display: flex;
    justify-content: space-around;
    {% comment %} gap: 20px; {% endcomment %}
    min-width: 100%;
    animation: scroll-marquee {{ section.settings.scroll_speed }}s linear infinite;
  }

  @keyframes scroll-marquee {
    from { transform: translateX(0); }
    to { transform: translateX(calc(-100% - 20px)); }
  }


</style>

<div class="result-section" id="section-{{ section.id }}">
  <div class="section-spacing">
    <div class="container">
      <div class="section-heading center">
        {% if section.settings.tagline != blank %}
          <p class="section-tag">{{ section.settings.tagline }}</p>
        {% endif %}
        <h2 class="section-title">{{ section.settings.title_start }} <span class="text-span-6">{{ section.settings.title_highlight }}</span> {{ section.settings.title_end }}</h2>
      </div>

      <div class="result-marquee">
        {% comment %} Marquee repeated for infinite scroll effect {% endcomment %}
        {% for i in (1..3) %}
          <div class="result-marquee-layout">
            {% for block in section.blocks %}
              <div class="result-item" {{ block.shopify_attributes }}>
                <div class="result-item-thumb-wrap">
                  {% if block.settings.image != blank %}
                    <img
                      src="{{ block.settings.image | image_url: width: 600 }}"
                      loading="lazy"
                      alt="{{ block.settings.image.alt | escape }}"
                      class="result-item-thumb"
                    />
                  {% endif %}
                  <div class="result-item-tag">
                    <div>{{ block.settings.name }}</div>
                  </div>
                </div>
                <div class="result-item-top">
                  <img
                    src="https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69aa983a6fb93a04481e5953_icon-8.svg"
                    loading="lazy"
                    alt=""
                    class="result-item-icon"
                  />
                  <p class="result-item-num">{{ block.settings.rating }}</p>
                </div>
                <h2 class="result-item-title">{{ block.settings.quote }}</h2>
                <p class="result-item-text">{{ block.settings.result_text }}</p>
              </div>
            {% endfor %}
          </div>
        {% endfor %}
      </div>

      <div class="hero-btn-wrap show">
        <a href="{{ section.settings.button_link }}" class="btn-blue w-inline-block">
          <div>{{ section.settings.button_text }}</div>
          <img
            src="https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69aa9bb30b981754d6b9d079_icon-9.svg"
            loading="lazy"
            alt=""
            class="hero-btn-icon"
          />
        </a>
        <div class="hero-content-bottom">
          <img
            src="https://cdn.prod.website-files.com/69a937b4bb797706ea5994c3/69aa9bb3f0071c12a2b7bc09_icon-10.svg"
            loading="lazy"
            alt=""
            class="hero-icon-2"
          />
          <p class="result-bottom-text">{{ section.settings.guarantee_text }}</p>
        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "LP Result Section",
  "tag": "section",
  "class": "lp-result-section",
  "settings": [
    {
      "type": "range",
      "id": "scroll_speed",
      "min": 5,
      "max": 100,
      "step": 5,
      "unit": "s",
      "label": "Scroll Speed (Higher is slower)",
      "default": 30
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Section Tagline",
      "default": "Verified Results"
    },
    {
      "type": "text",
      "id": "title_start",
      "label": "Section Title (before highlight)",
      "default": "Trusted by"
    },
    {
      "type": "text",
      "id": "title_highlight",
      "label": "Section Title (highlighted number)",
      "default": "60,000+"
    },
    {
      "type": "text",
      "id": "title_end",
      "label": "Section Title (after highlight)",
      "default": "Patients Nationwide"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button URL"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Label",
      "default": "Get Started for $83/month"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee Text",
      "default": "30-day weight loss guarantee"
    }
  ],
  "blocks": [
    {
      "type": "result_item",
      "name": "Result Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Patient Photo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Patient Name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "rating",
          "label": "Rating",
          "default": "4.9 / 5.0"
        },
        {
          "type": "text",
          "id": "quote",
          "label": "Quote",
          "default": "WeightRx made it simple to finally stick with a plan."
        },
        {
          "type": "text",
          "id": "result_text",
          "label": "Result Text",
          "default": "Sarah lost 38 lbs with WeightRx"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Result Section",
      "blocks": [
        { "type": "result_item" },
        { "type": "result_item" },
        { "type": "result_item" },
        { "type": "result_item" }
      ]
    }
  ]
}
{% endschema %}