{%- style -%}
  .section_about-lead-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    font-family: inherit;
  }
  
  .about-lead_list-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 40px 20px;
    list-style: none;
    padding: 0;
    margin: 0 auto;
    max-width: 1200px;
  }

  .about-lead_item {
    flex: 0 0 calc(33.33% - 20px);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .about-lead_img-wrap {
    width: 200px; /* Image size */
    height: 200px;
    border-radius: 50%; /* Isse image round/circle hogi */
    overflow: hidden;
    margin-bottom: 15px;
    border: 1px solid #e0e0e0; /* Halki border jaisa image mein hai */
  }

  .about-lead_img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-lead_text .name {
    font-size: 1.1rem;
    font-weight: 600;
    color: #333;
    margin-bottom: 4px;
  }

  .about-lead_text .position {
    font-size: 0.85rem;
    color: #777;
    text-transform: capitalize;
  }

  .heading-wrapper {
    margin-bottom: 50px;
    text-align: center;
  }

  .heading-wrapper h2 {
    font-size: 2.5rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: #1a1a1a;
  }

  /* Responsive Design */
  @media screen and (max-width: 991px) {
    .about-lead_item {
      flex: 0 0 calc(50% - 20px);
    }
    .about-lead_img-wrap {
      width: 160px;
      height: 160px;
    }
  }

  @media screen and (max-width: 480px) {
    .about-lead_item {
      flex: 0 0 100%;
    }
    .heading-wrapper h2 {
      font-size: 1.8rem;
    }
  }
{%- endstyle -%}

<section class="section_about-lead-{{ section.id }}">
  <div class="container" style="padding: 0 20px;">
    
    {%- if section.settings.heading != blank -%}
      <div class="heading-wrapper">
        <div class="rte-style-text">
          <h2>{{ section.settings.heading }}</h2>
        </div>
      </div>
    {%- endif -%}

    <ul role="list" class="about-lead_list-{{ section.id }}">
      {%- for block in section.blocks -%}
        <li class="about-lead_item" {{ block.shopify_attributes }}>
          <div class="about-lead_img-wrap">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 400 | image_tag: 
                loading: 'lazy', 
                class: 'about-lead_img',
                alt: block.settings.name
              }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'about-lead_img placeholder-svg' }}
            {%- endif -%}
          </div>
          
          <div class="about-lead_text">
            <div class="rte-style-text">
              <div class="name">{{ block.settings.name }}</div>
              <div class="position">{{ block.settings.position }}</div>
            </div>
          </div>
        </li>
      {%- endfor -%}
    </ul>

  </div>
</section>

{% schema %}
{
  "name": "Team Section Round",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Leading with vision, integrity and innovation"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "member",
      "name": "Team Member",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Member Photo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Adam McBride"
        },
        {
          "type": "text",
          "id": "position",
          "label": "Position",
          "default": "CEO, Cofounder"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Team Section Round",
      "blocks": [
        { "type": "member" },
        { "type": "member" },
        { "type": "member" },
        { "type": "member" },
        { "type": "member" }
      ]
    }
  ]
}
{% endschema %}