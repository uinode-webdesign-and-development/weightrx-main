{%- style -%}
  /* Section Layout */
  .section_experts-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
    width: 100%;
  }

  .experts_component-{{ section.id }} {
    width: 100%;
    padding-left: 5%; /* Slider aur arrows ko left side se thoda gap dene ke liye */
  }

  @media (max-width: 768px) {
    .experts_component-{{ section.id }} {
      padding-left: 20px;
    }
  }

  /* Slider Header */
  .experts_heading-wrap {
    margin-bottom: 40px;
    text-align: left; /* Heading ko bhi left rakha hai layout match karne ke liye */
  }

  .experts_heading-wrap h2 {
    margin: 0;
    font-size: 2rem;
    line-height: 1.2;
    color: #000;
  }

  /* Expert Card Styling */
  .experts-swiper-{{ section.id }} {
    width: 100%;
    overflow: visible; /* Taaki next slides cut-off na lagein aur full width look aaye */
  }

  .experts-v2.swiper-slide {
    height: auto;
    background: #fff;
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    border: 1px solid #e1e1e1;
    width: 320px; /* Card ki width */
    transition: box-shadow 0.3s ease;
  }

  .experts-v2.swiper-slide:hover {
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
  }

  .experts_v2-image-wrap {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 12px 12px 0 0;
    background-color: #f4f4f4;
  }

  .experts_v2-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .experts_v2-content {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .experts-v2-name {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 4px;
    color: #000;
  }

  .experts_v2-role {
    font-weight: 500;
    color: #666;
    margin-bottom: 12px;
    font-size: 1rem;
  }

  .experts_v2-bio {
    font-size: 0.95rem;
    line-height: 1.5;
    color: #333;
    margin: 0;
  }

  /* Navigation Arrows - Fixed to Bottom Left */
  .swiper-nav-wrap-{{ section.id }} { 
    margin-top: 30px; 
    display: flex; 
    justify-content: flex-start; /* Arrows are now left-aligned */
    padding-bottom: 10px;
  }
  
  .swiper-nav-{{ section.id }} { 
    display: flex; 
    gap: 15px; 
    align-items: center; 
  }
  
  .swiper_nav-button-{{ section.id }} {
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    width: 48px; 
    height: 48px;
    flex-shrink: 0;
  }

  .swiper_nav-button-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Arrows look disabled when at start/end but never hide */
  .swiper_nav-button-{{ section.id }}.swiper-button-disabled { 
    opacity: 0.2; 
    cursor: not-allowed; 
    pointer-events: none;
  }

  .swiper_nav-button-{{ section.id }}:hover:not(.swiper-button-disabled) {
    transform: scale(1.1);
  }
{%- endstyle -%}

<!-- Swiper.js CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<section class="section_experts-{{ section.id }}">
  <div class="experts_component-{{ section.id }}">
    
    {% if section.settings.heading != blank %}
      <div class="experts_heading-wrap">
        <h2>{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="swiper experts-swiper-{{ section.id }}">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide experts-v2" {{ block.shopify_attributes }}>
            <div class="experts_v2-image-wrap">
              {% if block.settings.expert_image != blank %}
                {{ block.settings.expert_image | image_url: width: 600 | image_tag: class: 'experts_v2-image', loading: 'lazy' }}
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'experts_v2-image' }}
              {% endif %}
            </div>
            <div class="experts_v2-content">
              <div class="experts_v2-title">
                <div class="experts-v2-name">{{ block.settings.name }}</div>
                <div class="experts_v2-role">{{ block.settings.role }}</div>
              </div>
              <div class="experts_v2-bio">
                {{ block.settings.bio }}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <!-- Navigation Arrows - Always Visible at Bottom Left -->
    <div class="swiper-nav-wrap-{{ section.id }}">
      <div class="swiper-nav-{{ section.id }}">
        <button class="swiper_nav-button-{{ section.id }} exp-prev-{{ section.id }}">
          {% if section.settings.arrow_prev != blank %}
            {{ section.settings.arrow_prev | image_url: width: 100 | image_tag }}
          {% else %}
            <!-- Default SVG Arrow if no image picked -->
            <img src="https://cdn.prod.website-files.com/676eb86a8ca7187507487da6/68c415fc8de7c203054cbc11_Arrow_Prev.svg" alt="Previous">
          {% endif %}
        </button>
        
        <button class="swiper_nav-button-{{ section.id }} exp-next-{{ section.id }}">
          {% if section.settings.arrow_next != blank %}
            {{ section.settings.arrow_next | image_url: width: 100 | image_tag }}
          {% else %}
            <!-- Default SVG Arrow if no image picked -->
            <img src="https://cdn.prod.website-files.com/676eb86a8ca7187507487da6/68c415fcebd2f456b997e139_Arrow-Next.svg" alt="Next">
          {% endif %}
        </button>
      </div>
    </div>

  </div>
</section>

<!-- Swiper.js Script -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  function initExpertsSlider{{ section.id | replace: '-', '_' }}() {
    const swiper = new Swiper('.experts-swiper-{{ section.id }}', {
      speed: 400,
      slidesPerView: 'auto',
      spaceBetween: 20,
      loop: false,
      grabCursor: true,
      navigation: {
        nextEl: ".exp-next-{{ section.id }}",
        prevEl: ".exp-prev-{{ section.id }}",
      },
    });
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', initExpertsSlider{{ section.id | replace: '-', '_' }});
  
  // Re-initialize when section is adjusted in Shopify Editor
  document.addEventListener('shopify:section:load', function(event) {
    if (event.detail.sectionId === '{{ section.id }}') {
      initExpertsSlider{{ section.id | replace: '-', '_' }}();
    }
  });
</script>

{% schema %}
{
  "name": "Experts Slider Left-Nav",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Meet Eden's trusted medical team"
    },
    {
      "type": "header",
      "content": "Custom Navigation Icons"
    },
    {
      "type": "image_picker",
      "id": "arrow_prev",
      "label": "Previous Arrow Icon"
    },
    {
      "type": "image_picker",
      "id": "arrow_next",
      "label": "Next Arrow Icon"
    },
    {
      "type": "header",
      "content": "Style Settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "expert",
      "name": "Expert Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "expert_image",
          "label": "Expert Headshot"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Dr. Halland Chen, M.D."
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role",
          "default": "Chief Medical Innovation Officer"
        },
        {
          "type": "richtext",
          "id": "bio",
          "label": "Bio Description",
          "default": "<p>Expertise in longevity medicine, regenerative medicine, and anti-aging care.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Experts Slider Left-Nav",
      "blocks": [
        { "type": "expert" },
        { "type": "expert" },
        { "type": "expert" },
        { "type": "expert" }
      ]
    }
  ]
}
{% endschema %}