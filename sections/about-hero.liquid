{% comment %}
  Eden - Professional About Hero Section
  Shopify Section: about-hero
{% endcomment %}

<style>
  :root {
    --transition-base: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    --card-radius: 1.5rem;
    --dark-bg: #1d1d1f;
    --light-bg: #f5f5f7;
  }

  .section_about-hero {
    background-color: var(--light-bg);
    padding: 100px 0;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .container-main {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 40px;
    width: 100%;
  }

  .about-hero_component {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 80px;
    align-items: center;
  }

  /* --- LEFT CONTENT STYLE --- */
  .about-hero_content {
    display: flex;
    flex-direction: column;
    gap: 28px;
    animation: fadeInUp 0.8s ease-out;
  }

  .heading-style-h1 {
    font-size: clamp(2.8rem, 6vw, 4.2rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--dark-bg);
    margin: 0;
  }

  .subheading-wrap {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 520px;
  }

  .text-size-large {
    font-size: 1.25rem;
    line-height: 1.4;
    color: #1d1d1f;
    font-weight: 600;
  }

  .body-text-p {
    font-size: 1rem;
    line-height: 1.6;
    color: #515154;
  }

  /* --- RIGHT GRID STYLE --- */
  .about-hero_list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    perspective: 1000px;
  }

  .about-hero_col {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .about-hero_col.col-offset {
    padding-top: 40px;
  }

  /* --- CARD FRAME DESIGN --- */
  .about-hero_frame {
    display: block;
    position: relative;
    border-radius: var(--card-radius);
    overflow: hidden;
    text-decoration: none;
    background: #e8e8ed;
    transition: var(--transition-base);
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    z-index: 1;
  }

  .about-hero_frame:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.12);
    z-index: 2;
  }

  .about-hero_frame-img-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .about-hero_frame-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s ease;
  }

  .about-hero_frame:hover .about-hero_frame-img {
    transform: scale(1.08);
  }

  /* Overlay for text readability */
  .about-hero_frame::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0) 40%, rgba(0,0,0,0.2) 100%);
    opacity: 1;
    z-index: 1;
  }

  /* --- TEXT & ICON POSITIONING --- */
  .about-hero_frame-content {
    position: absolute;
    inset: 0;
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: space-between; /* Top to Bottom spacing */
    align-items: flex-start; /* Start from left */
    z-index: 5;
  }

  .about-hero_frame-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0;
    text-shadow: 0 2px 4px rgba(0,0,0,0.2);
    max-width: 90%;
    transform: translateY(0);
    transition: var(--transition-base);
  }

  .about-hero_frame-icon {
    align-self: flex-end; /* Bottom Right align */
    width: 44px;
    height: 44px;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.3);
    transition: var(--transition-base);
  }

  .about-hero_frame:hover .about-hero_frame-icon {
    background: #ffffff;
    color: var(--dark-bg);
    transform: rotate(-45deg);
  }

  .about-hero_frame-icon svg {
    width: 22px;
    height: 22px;
  }

  /* --- ANIMATIONS --- */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* --- RESPONSIVE SETTINGS --- */
  @media (max-width: 1024px) {
    .about-hero_component {
      grid-template-columns: 1fr;
      gap: 60px;
    }
    .about-hero_content {
      max-width: 100%;
      text-align: center;
      align-items: center;
    }
    .subheading-wrap { max-width: 100%; }
  }

  @media (max-width: 768px) {
    .section_about-hero { padding: 60px 0; }
    .container-main { padding: 0 20px; }
    .about-hero_list { gap: 15px; }
    .about-hero_col.col-offset { padding-top: 0; }
    .about-hero_frame-content { padding: 16px; }
  }

  @media (max-width: 480px) {
    .about-hero_list { grid-template-columns: 1fr; }
    .heading-style-h1 { font-size: 2.2rem; }
  }
</style>

<section id="{{ section.id }}" class="section_about-hero">
  <div class="container-main">
    <div class="about-hero_component">

      <!-- Left Side: Content -->
      <div class="about-hero_content">
        {% if section.settings.heading != blank %}
          <h1 class="heading-style-h1">{{ section.settings.heading }}</h1>
        {% endif %}

        <div class="subheading-wrap">
          {% if section.settings.subheading != blank %}
            <p class="text-size-large">{{ section.settings.subheading }}</p>
          {% endif %}

          {% if section.settings.body_text != blank %}
            <p class="body-text-p">{{ section.settings.body_text }}</p>
          {% endif %}
        </div>
      </div>

      <!-- Right Side: Interactive Cards -->
      <div class="about-hero_list">
        
        {%- comment -%} Loop for Column 1 {%- endcomment -%}
        <div class="about-hero_col">
          {% for block in section.blocks %}
            {% if block.settings.column == '1' %}
              {% render 'hero-card-item', block: block %}
            {% endif %}
          {% endfor %}
        </div>

        {%- comment -%} Loop for Column 2 {%- endcomment -%}
        <div class="about-hero_col col-offset">
          {% for block in section.blocks %}
            {% if block.settings.column == '2' %}
              {% render 'hero-card-item', block: block %}
            {% endif %}
          {% endfor %}
        </div>

      </div>
    </div>
  </div>
</section>

{% comment %} 
  Inlined Snippet Logic 
  (Normally you'd put this in a snippet, but I'm putting it here for "full code")
{% endcomment %}
{%- capture card_item -%}
{%- endcapture -%}

{% schema %}
{
  "name": "About Hero Custom",
  "settings": [
    {
      "type": "header",
      "content": "Main Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Quality care, made simple"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Expert medical support for your journey."
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body Text",
      "default": "We assist you in enrolling in plans tailored to support weight management and overall health."
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Treatment Card",
      "settings": [
        {
          "type": "header",
          "content": "Layout Settings"
        },
        {
          "type": "select",
          "id": "column",
          "label": "Select Column",
          "options": [
            { "value": "1", "label": "Left Column" },
            { "value": "2", "label": "Right Column" }
          ],
          "default": "1"
        },
        {
          "type": "text",
          "id": "aspect_ratio",
          "label": "Card Aspect Ratio (H/W)",
          "info": "Example: 1/1 (Square), 4/5 (Portrait), 16/9 (Wide)",
          "default": "1/1"
        },
        {
          "type": "range",
          "id": "card_width",
          "min": 50,
          "max": 100,
          "step": 5,
          "unit": "%",
          "label": "Card Max Width",
          "default": 100
        },
        {
          "type": "header",
          "content": "Content Settings"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "default": "Treatment Name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card URL"
        },
        {
          "type": "checkbox",
          "id": "show_icon",
          "label": "Show Bottom-Right Icon",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Hero Full",
      "blocks": [
        { "type": "card", "settings": { "column": "1", "aspect_ratio": "1/1.2" } },
        { "type": "card", "settings": { "column": "1", "aspect_ratio": "1/0.8" } },
        { "type": "card", "settings": { "column": "2", "aspect_ratio": "1/0.8" } },
        { "type": "card", "settings": { "column": "2", "aspect_ratio": "1/1.2" } }
      ]
    }
  ]
}
{% endschema %}

{%- comment -%} 
  This part handles the block rendering with the custom height/width options
{%- endcomment -%}
{%- for block in section.blocks -%}
  {%- style -%}
    [data-block-id="{{ block.id }}"] {
      aspect-ratio: {{ block.settings.aspect_ratio }};
      max-width: {{ block.settings.card_width }}%;
    }
  {%- endstyle -%}
{%- endfor -%}

{%- comment -%} Use this inside the loops above instead of the render tag if not using snippets {%- endcomment -%}
{%- capture card_render -%}
  {%- for block in section.blocks -%}
    {%- comment -%} Logic inside the HTML loop {%- endcomment -%}
  {%- endfor -%}
{%- endcapture -%}