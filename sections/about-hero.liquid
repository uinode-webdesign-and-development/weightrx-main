{% comment %}
  Eden - Full Integrated About Hero Section
  Shopify Section: about-hero
{% endcomment %}

<style>
  :root {
    --transition-base: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    --card-radius: 1.5rem;
    --dark-bg: #1d1d1f;
    --light-bg: #f5f5f7;
  }

  .section_about-hero {
    background-color: var(--light-bg);
    padding: 80px 0;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .container-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    width: 100%;
  }

  .about-hero_component {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .about-hero_content {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 480px;
  }

  .heading-style-h1 {
    font-size: clamp(2.5rem, 5vw, 3.8rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--dark-bg);
    margin: 0;
  }

  .text-size-large {
    font-size: 1.2rem;
    line-height: 1.5;
    color: var(--dark-bg);
    font-weight: 600;
    margin: 0;
  }

  .body-text-p {
    font-size: 1rem;
    line-height: 1.6;
    color: #3d3d3d;
    margin: 0;
  }

  .about-hero_list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .about-hero_col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .about-hero_frame {
    display: block;
    position: relative;
    border-radius: var(--card-radius);
    overflow: hidden;
    text-decoration: none;
    background: #1d1d1f;
    transition: var(--transition-base);
    width: 100%;
  }

  .about-hero_frame:hover {
    box-shadow: 0 12px 30px rgba(0,0,0,0.15);
    transform: translateY(-4px);
  }

  .about-hero_frame-img-wrap {
    position: absolute;
    inset: 0;
  }

  .about-hero_frame-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .about-hero_frame:hover .about-hero_frame-img {
    transform: scale(1.1);
  }

  /* TOP LEFT TEXT POSITION */
  .about-hero_frame-content {
    position: absolute;
    inset: 0;
    padding: 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between; 
    align-items: flex-start;
    z-index: 2;
    background: linear-gradient(180deg, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0) 50%);
  }

  .about-hero_frame-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #fff;
    margin: 0;
    line-height: 1.2;
  }

  /* BOTTOM RIGHT ICON POSITION */
  .about-hero_frame-icon {
    align-self: flex-end;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: rgba(255,255,255,0.2);
    backdrop-filter: blur(4px);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-base);
  }

  .about-hero_frame:hover .about-hero_frame-icon {
    background-color: #fff;
    color: #000;
  }

  @media (max-width: 991px) {
    .about-hero_component { grid-template-columns: 1fr; gap: 40px; }
    .about-hero_content { max-width: 100%; }
    .about-hero_list { max-width: 600px; margin: 0 auto; width: 100%; }
  }

  @media (max-width: 479px) {
    .about-hero_list { grid-template-columns: 1fr; }
  }
</style>

<section id="{{ section.id }}" class="section_about-hero">
  <div class="container-main">
    <div class="about-hero_component">

      <div class="about-hero_content">
        {% if section.settings.heading != blank %}
          <h1 class="heading-style-h1">{{ section.settings.heading }}</h1>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="text-size-large">{{ section.settings.subheading }}</p>
        {% endif %}
        {% if section.settings.body_text != blank %}
          <p class="body-text-p">{{ section.settings.body_text }}</p>
        {% endif %}
      </div>

      <div class="about-hero_list">
        {% for i in (1..2) %}
          <div class="about-hero_col">
            {% assign col_num = i | append: "" %}
            {% for block in section.blocks %}
              {% if block.settings.column == col_num %}
                
                {% capture tag %}{% if block.settings.link != blank %}a{% else %}div{% endif %}{% endcapture %}
                
                <{{ tag }} 
                  {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}
                  class="about-hero_frame" 
                  style="aspect-ratio: {{ block.settings.aspect_ratio }};"
                  {{ block.shopify_attributes }}>

                  <div class="about-hero_frame-img-wrap">
                    {% if block.settings.image != blank %}
                      <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title }}" class="about-hero_frame-img" loading="lazy">
                    {% endif %}
                  </div>

                  <div class="about-hero_frame-content">
                    {% if block.settings.title != blank %}
                      <p class="about-hero_frame-title">{{ block.settings.title }}</p>
                    {% endif %}
                    
                    {% if block.settings.show_icon %}
                      <div class="about-hero_frame-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M6 18L18 6M18 6H9M18 6V15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </div>
                    {% endif %}
                  </div>
                </{{ tag }}>

              {% endif %}
            {% endfor %}
          </div>
        {% endfor %}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Hero Fixed",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Quality care, made simple" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Eden connects you..." },
    { "type": "textarea", "id": "body_text", "label": "Body Text", "default": "We assist you..." }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Column",
          "options": [
            { "value": "1", "label": "Column 1" },
            { "value": "2", "label": "Column 2" }
          ],
          "default": "1"
        },
        {
          "type": "text",
          "id": "aspect_ratio",
          "label": "Aspect Ratio (H/W)",
          "default": "1/1",
          "info": "Example: 1/1, 3/4, 4/3"
        },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Treatment" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "checkbox", "id": "show_icon", "label": "Show Icon", "default": true }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Hero Fixed",
      "blocks": [
        { "type": "card", "settings": { "column": "1", "aspect_ratio": "1/1.2" } },
        { "type": "card", "settings": { "column": "2", "aspect_ratio": "1/0.8" } }
      ]
    }
  ]
}
{% endschema %}