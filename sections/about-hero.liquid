{% comment %}
  Eden - Complete About Hero Section
  Features: Top-left text, Bottom-right custom arrow, Aspect ratio & Width control.
{% endcomment %}

<style>
  .section_about-hero {
    padding: 60px 0 80px;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .container-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    width: 100%;
  }

  .about-hero_component {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .about-hero_content {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 550px;
}

h4.heading-style-h4 {
    font-weight: 500;
    margin: 22px 0;
}

.about-hero_content p {
    font-weight: 300;
    color: #00000098;
}

  .heading-style-h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    color: #1d1d1f;
    margin: 0;
  }

  /* Cards Grid */
  .about-hero_list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .about-hero_col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Individual Card */
  .about-hero_frame {
    display: block;
    position: relative;
    border-radius: 28px;
    overflow: hidden;
    text-decoration: none;
    background: #1d1d1f;
    transition: all 0.4s ease;
    margin-left: auto;
    margin-right: auto;
    cursor: pointer;
  }

  .about-hero_frame:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
  }

  .about-hero_frame-img-wrap {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .about-hero_frame-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .about-hero_frame:hover .about-hero_frame-img {
    transform: scale(1.05);
  }

  /* Content Overlay: Top-Left Text, Bottom-Right Icon */
  .about-hero_frame-content {
    position: absolute;
    inset: 0;
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: space-between; /* Yeh text ko upar aur icon ko neeche rakhta hai */
    align-items: flex-start; /* Text left par */
    z-index: 2;
    background: linear-gradient(180deg, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0) 50%);
  }

  .about-hero_frame-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: #ffffff;
    margin: 0;
    line-height: 1.2;
  }

  /* Icon Style */
  .about-hero_frame-icon {
    align-self: flex-end; /* Icon ko right par push karta hai */
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(5px);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .about-hero_frame:hover .about-hero_frame-icon {
    background: #ffffff;
  }

  .about-hero_frame-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 10px;
  }

  .about-hero_frame-icon svg {
    width: 20px;
    height: 20px;
    color: #ffffff;
  }
  
  .about-hero_frame:hover .about-hero_frame-icon svg {
    color: #000000;
  }

  @media (max-width: 991px) {
    .about-hero_component { grid-template-columns: 1fr; }
    .about-hero_list { max-width: 600px; margin: 0 auto; }
  }

  @media (max-width: 480px) {
    .about-hero_list { grid-template-columns: 1fr; }
  }
</style>

<section id="{{ section.id }}" class="section_about-hero">
  <div class="container">
    <div class="about-hero_component">

      <!-- Text Content -->
      <div class="about-hero_content">
        <div class="rte-style-text">
          {% if section.settings.heading != blank %}
            <h1 class="heading-style-h1">{{ section.settings.heading }}</h1>
          {% endif %}
          {% if section.settings.subheading != blank %}
            <h4 class="heading-style-h4">{{ section.settings.subheading }}</h4>
          {% endif %}
          {% if section.settings.body_text != blank %}
            <p>{{ section.settings.body_text }}</p>
          {% endif %}
        </div>
      </div>

      <!-- Cards Grid -->
      <div class="about-hero_list">
        {% for i in (1..2) %}
          <div class="about-hero_col">
            {% assign col_num = i | append: "" %}
            {% for block in section.blocks %}
              {% if block.settings.column == col_num %}
                
                {% capture tag %}{% if block.settings.link != blank %}a{% else %}div{% endif %}{% endcapture %}
                
                <{{ tag }} 
                  {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}
                  class="about-hero_frame" 
                  style="aspect-ratio: {{ block.settings.aspect_ratio }}; width: {{ block.settings.card_width }}%;"
                  {{ block.shopify_attributes }}>

                  <!-- Background Image -->
                  <div class="about-hero_frame-img-wrap">
                    {% if block.settings.image != blank %}
                      {{ block.settings.image | image_url: width: 800 | image_tag: class: 'about-hero_frame-img', loading: 'lazy' }}
                    {% endif %}
                  </div>

                  <!-- Content Overlay -->
                  <div class="about-hero_frame-content">
                    {% if block.settings.title != blank %}
                      <p class="about-hero_frame-title">{{ block.settings.title }}</p>
                    {% endif %}
                    
                    {% if block.settings.show_icon %}
                      <div class="about-hero_frame-icon">
                        {% if block.settings.custom_arrow != blank %}
                          <img src="{{ block.settings.custom_arrow | image_url: width: 50 }}" alt="arrow icon">
                        {% else %}
                          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        {% endif %}
                      </div>
                    {% endif %}
                  </div>
                </{{ tag }}>

              {% endif %}
            {% endfor %}
          </div>
        {% endfor %}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Hero Complete",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Quality care, made simple" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Eden connects you..." },
    { "type": "textarea", "id": "body_text", "label": "Body Text", "default": "We assist you..." }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Column",
          "options": [
            { "value": "1", "label": "Column 1 (Left)" },
            { "value": "2", "label": "Column 2 (Right)" }
          ],
          "default": "1"
        },
        {
          "type": "text",
          "id": "aspect_ratio",
          "label": "Card Aspect Ratio (e.g. 1/1, 3/4, 4/3)",
          "default": "1/1"
        },
        {
          "type": "range",
          "id": "card_width",
          "min": 50,
          "max": 100,
          "step": 5,
          "unit": "%",
          "label": "Card Width",
          "default": 100
        },
        { "type": "image_picker", "id": "image", "label": "Background Image" },
        { "type": "text", "id": "title", "label": "Title (Top-Left)", "default": "Treatment Title" },
        { "type": "url", "id": "link", "label": "Card Link" },
        { "type": "checkbox", "id": "show_icon", "label": "Show Arrow Icon", "default": true },
        {
          "type": "image_picker",
          "id": "custom_arrow",
          "label": "Custom Arrow/Icon Picker",
          "info": "Upload PNG or SVG. Leave empty for default arrow."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Hero Complete",
      "blocks": [
        { "type": "card", "settings": { "column": "1", "aspect_ratio": "3/4" } },
        { "type": "card", "settings": { "column": "2", "aspect_ratio": "1/1" } }
      ]
    }
  ]
}
{% endschema %}