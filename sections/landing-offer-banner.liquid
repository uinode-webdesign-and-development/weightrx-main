{% comment %} Build background image styles {% endcomment %}
{% assign bg_styles = '' %}
{% if section.settings.background_image != blank %}
  {% assign bg_image_url = section.settings.background_image | image_url: width: 2000 %}
  {% assign bg_styles = 'background-image: url(' | append: bg_image_url | append: ');' %}
  {% assign bg_styles = bg_styles | append: 'background-size: ' | append: section.settings.background_size | append: ';' %}
  {% assign bg_styles = bg_styles | append: 'background-position: ' | append: section.settings.background_position | append: ';' %}
  {% assign bg_styles = bg_styles | append: 'background-repeat: no-repeat;' %}
{% endif %}

<section
  class="offer-banner{% if section.settings.background_image != blank %} offer-banner--has-bg{% endif %}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    width: 100%;
    {{ bg_styles }}
    position: relative;
  "
>
  {% comment %} Overlay layer {% endcomment %}
  {% if section.settings.background_image != blank and section.settings.show_overlay %}
    <div
      class="offer-banner__overlay"
      style="
        position: absolute;
        inset: 0;
        background-color: {{ section.settings.overlay_color }};
        opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
        pointer-events: none;
        z-index: 0;
      "
    ></div>
  {% endif %}

  <div class="offer-banner__container" style="position: relative; z-index: 1;">
    <div class="offer-banner__header">
      <p class="offer-banner__spots">
        <b class="offer-banner__bold">
          <span class="offer-banner__counter">{{ section.settings.counter_first }}</span>
          <span class="offer-banner__counter">{{ section.settings.counter_second }}</span>
        </b>
        {{ section.settings.spots_text }}
      </p>
      <div class="offer-banner__title-container">
        <h1 class="offer-banner__title">
          {{ section.settings.title_prefix }}
          <span class="offer-banner__highlight">{{ section.settings.title_highlight }}</span>
          <span>{{ section.settings.title_middle }}</span>
          <b style="display: inline" class="offer-banner__bold">{{ section.settings.title_bold }}</b>
        </h1>
      </div>
    </div>

    <div class="offer-banner__features">
      {% for block in section.blocks %}
        {% if block.type == 'feature' %}
          <div class="offer-banner__feature-item" {{ block.shopify_attributes }}>
            <div class="offer-banner__feature-content">
              <div class="offer-banner__feature-icon-group">

                {% comment %} Icon: image_picker se upload ki hui image (SVG/PNG) {% endcomment %}
                {% if block.settings.icon_image != blank %}
                  <div class="offer-banner__feature-icon-wrap">
                    <img
                      src="{{ block.settings.icon_image | image_url: width: 80 }}"
                      alt="{{ block.settings.icon_image.alt | default: '' | escape }}"
                      width="{{ block.settings.icon_size }}"
                      height="{{ block.settings.icon_size }}"
                      class="offer-banner__feature-icon-img"
                      style="width: {{ block.settings.icon_size }}px; height: {{ block.settings.icon_size }}px; object-fit: contain; display: block;"
                      loading="lazy"
                    >
                  </div>
                {% endif %}

                <div class="offer-banner__feature-text">
                  {{ block.settings.feature_text }}
                </div>

              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="offer-banner__cta-section">
      <p class="offer-banner__press">
        {{ section.settings.press_text }}
      </p>
      <a
        class="offer-banner__button js-quiz-link"
        href="{{ section.settings.button_link }}"
        data-testid="quiz-button"
      >
        {{ section.settings.button_label }}
        <svg class="offer-banner__button-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Offer banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "select",
      "id": "background_size",
      "label": "Background size",
      "default": "cover",
      "options": [
        { "value": "cover", "label": "Cover (fill section)" },
        { "value": "contain", "label": "Contain (fit inside)" },
        { "value": "auto", "label": "Auto (original size)" }
      ]
    },
    {
      "type": "select",
      "id": "background_position",
      "label": "Background position",
      "default": "center center",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "top center", "label": "Top center" },
        { "value": "bottom center", "label": "Bottom center" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay on background image",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "header",
      "content": "Counter & Spots"
    },
    {
      "type": "text",
      "id": "counter_first",
      "label": "Counter first digit",
      "default": "2"
    },
    {
      "type": "text",
      "id": "counter_second",
      "label": "Counter second digit",
      "default": "5"
    },
    {
      "type": "text",
      "id": "spots_text",
      "label": "Spots text",
      "default": "spots left"
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "text",
      "id": "title_prefix",
      "label": "Title prefix",
      "default": "Secure"
    },
    {
      "type": "text",
      "id": "title_highlight",
      "label": "Title highlight",
      "default": "your"
    },
    {
      "type": "text",
      "id": "title_middle",
      "label": "Title middle",
      "default": "spot"
    },
    {
      "type": "text",
      "id": "title_bold",
      "label": "Title bold text",
      "default": "TODAY!"
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "richtext",
      "id": "press_text",
      "label": "Press text",
      "default": "<p>Recommended by <strong>Forbes, USA Today, and more</strong></p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Get Started Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Spacing"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon image (SVG ya PNG upload karein)"
        },
        {
          "type": "range",
          "id": "icon_size",
          "label": "Icon size",
          "min": 16,
          "max": 80,
          "step": 4,
          "unit": "px",
          "default": 32
        },
        {
          "type": "richtext",
          "id": "feature_text",
          "label": "Feature text",
          "default": "<p><strong>UNLIMITED</strong> doctor access &amp; lab reviews</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Offer banner",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}
