<footer class="custom-footer">
  <div class="custom-footer__inner">

    {% comment %} LEFT: Logo + Copyright {% endcomment %}
    <div class="custom-footer__brand">
      {% if section.settings.logo != blank %}
        <a href="{{ routes.root_url }}" class="custom-footer__logo-link">
          <img
            src="{{ section.settings.logo | image_url: width: 300 }}"
            alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
            width="{{ section.settings.logo_width }}"
            class="custom-footer__logo-img"
            loading="lazy"
            style="max-width: {{ section.settings.logo_width }}px;"
          >
        </a>
      {% else %}
        <a href="{{ routes.root_url }}" class="custom-footer__logo-text">
          {{ section.settings.brand_name | default: shop.name }}
        </a>
      {% endif %}

      <p class="custom-footer__copyright">
        {% if section.settings.copyright_text != blank %}
          {{ section.settings.copyright_text | replace: '[year]', 'now' | date: '%Y' }}
        {% else %}
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
        {% endif %}
      </p>
    </div>

    {% comment %} CENTER: Badge/Image {% endcomment %}
    <div class="custom-footer__center">
      {% if section.settings.center_image != blank %}
        <div class="custom-footer__badge">
          {% if section.settings.center_image_link != blank %}
            <a href="{{ section.settings.center_image_link }}" target="_blank" rel="noopener noreferrer">
              <img
                src="{{ section.settings.center_image | image_url: width: 200 }}"
                alt="{{ section.settings.center_image_alt | default: 'Badge' | escape }}"
                width="{{ section.settings.center_image_width }}"
                class="custom-footer__badge-img"
                loading="lazy"
              >
            </a>
          {% else %}
            <img
              src="{{ section.settings.center_image | image_url: width: 200 }}"
              alt="{{ section.settings.center_image_alt | default: 'Badge' | escape }}"
              width="{{ section.settings.center_image_width }}"
              class="custom-footer__badge-img"
              loading="lazy"
            >
          {% endif %}
        </div>
      {% endif %}
    </div>

    {% comment %} RIGHT: Heading + Contact Info + Menu {% endcomment %}
    <div class="custom-footer__contact">
      {% if section.settings.contact_heading != blank %}
        <p class="custom-footer__contact-heading">{{ section.settings.contact_heading }}</p>
      {% endif %}

      <div class="custom-footer__info-group">
        {% for block in section.blocks %}
          {% if block.type == 'contact_line' %}
            <div class="custom-footer__contact-line" {{ block.shopify_attributes }}>
              {% if block.settings.line_icon != blank %}
                <span class="custom-footer__contact-icon">{{ block.settings.line_icon }}</span>
              {% endif %}
              <span>{{ block.settings.line_text }}</span>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% comment %} Links are now directly under contact info {% endcomment %}
      {% if section.settings.footer_menu != blank %}
        {% assign footer_nav = linklists[section.settings.footer_menu] %}
        {% if footer_nav.links.size > 0 %}
          <div class="custom-footer__inline-links">
            {% for link in footer_nav.links %}
              <a href="{{ link.url }}" class="custom-footer__link-item">{{ link.title }}</a>
            {% endfor %}
          </div>
        {% endif %}
      {% endif %}
    </div>

  </div>
</footer>

<style>
  .custom-footer {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    width: 100%;
  }

  .custom-footer__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center; 
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }

  /* ── LEFT ── */
  .custom-footer__brand {
    flex: 1;
    min-width: 180px;
  }
  .custom-footer__logo-img {
    display: block;
    height: auto;
    margin-bottom: 8px;
  }
  .custom-footer__copyright {
    color: {{ section.settings.text_color }};
    font-size: 13px;
    margin: 0;
    opacity: 0.8;
  }

  /* ── CENTER ── */
  .custom-footer__center {
    flex: 0 0 auto;
  }
  .custom-footer__badge-img {
    display: block;
    height: auto;
  }

  /* ── RIGHT (The main change) ── */
  .custom-footer__contact {
    flex: 1;
    min-width: 300px;
    display: flex;
    flex-direction: column;
    align-items: flex-start; /* Matches the left-aligned text in your screenshot */
    text-align: left;
  }

  .custom-footer__contact-heading {
    color: {{ section.settings.text_color }};
    font-size: 15px;
    font-weight: 700;
    margin: 0 0 10px 0;
  }

  .custom-footer__info-group {
    display: flex;
    flex-direction: column;
    gap: 5px;
    margin-bottom: 12px;
  }

  .custom-footer__contact-line {
    color: {{ section.settings.text_color }};
    font-size: 13px;
    line-height: 1.4;
    opacity: 0.9;
    display: flex;
    gap: 8px;
  }

  /* Inline Menu Links */
  .custom-footer__inline-links {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    margin-top: 5px;
  }

  .custom-footer__link-item {
    color: {{ section.settings.text_color }};
    font-size: 12px;
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .custom-footer__link-item:hover {
    opacity: 1;
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .custom-footer__inner {
      flex-direction: column;
      text-align: center;
      align-items: center;
    }
    .custom-footer__contact {
      align-items: center;
      text-align: center;
    }
    .custom-footer__inline-links {
      justify-content: center;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 60,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 140
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "WeightRx"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "© [year] WeightRx"
    },
    {
      "type": "header",
      "content": "Center Badge"
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Center image"
    },
    {
      "type": "range",
      "id": "center_image_width",
      "label": "Center image width",
      "min": 40,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "url",
      "id": "center_image_link",
      "label": "Image link"
    },
    {
      "type": "header",
      "content": "Right Column"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact heading",
      "default": "Contact Care Team"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Menu (Privacy, Terms etc.)",
      "info": "Ye links contact details ke niche show honge"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1A237E"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Max width (px)",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "contact_line",
      "name": "Contact line",
      "settings": [
        {
          "type": "text",
          "id": "line_icon",
          "label": "Icon (optional)"
        },
        {
          "type": "text",
          "id": "line_text",
          "label": "Line text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Footer"
    }
  ]
}
{% endschema %}