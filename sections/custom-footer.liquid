<footer class="custom-footer">
  <div class="custom-footer__inner">

    {% comment %} LEFT: Logo + Copyright {% endcomment %}
    <div class="custom-footer__brand">
      {% if section.settings.logo != blank %}
        <a href="{{ routes.root_url }}" class="custom-footer__logo-link">
          <img
            src="{{ section.settings.logo | image_url: width: 300 }}"
            alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
            width="{{ section.settings.logo_width }}"
            class="custom-footer__logo-img"
            loading="lazy"
            style="max-width: {{ section.settings.logo_width }}px;"
          >
        </a>
      {% else %}
        <a href="{{ routes.root_url }}" class="custom-footer__logo-text">
          {{ section.settings.brand_name | default: shop.name }}
        </a>
      {% endif %}

      <p class="custom-footer__copyright">
        {% if section.settings.copyright_text != blank %}
          {{ section.settings.copyright_text | replace: '[year]', 'now' | date: '%Y' }}
        {% else %}
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
        {% endif %}
      </p>
    </div>

    {% comment %} CENTER: Badge/Image {% endcomment %}
    <div class="custom-footer__center">
      {% if section.settings.center_image != blank %}
        <div class="custom-footer__badge">
          {% if section.settings.center_image_link != blank %}
            <a href="{{ section.settings.center_image_link }}" target="_blank" rel="noopener noreferrer">
              <img
                src="{{ section.settings.center_image | image_url: width: 200 }}"
                alt="{{ section.settings.center_image_alt | default: 'Badge' | escape }}"
                width="{{ section.settings.center_image_width }}"
                class="custom-footer__badge-img"
                loading="lazy"
              >
            </a>
          {% else %}
            <img
              src="{{ section.settings.center_image | image_url: width: 200 }}"
              alt="{{ section.settings.center_image_alt | default: 'Badge' | escape }}"
              width="{{ section.settings.center_image_width }}"
              class="custom-footer__badge-img"
              loading="lazy"
            >
          {% endif %}
        </div>
      {% endif %}
    </div>

    {% comment %} RIGHT: Contact Info (All items appear here) {% endcomment %}
    <div class="custom-footer__contact">
      {% if section.settings.contact_heading != blank %}
        <p class="custom-footer__contact-heading">{{ section.settings.contact_heading }}</p>
      {% endif %}

      {% for block in section.blocks %}
        {% if block.type == 'contact_line' %}
          <div class="custom-footer__contact-line" {{ block.shopify_attributes }}>
            {% if block.settings.line_icon != blank %}
              <span class="custom-footer__contact-icon">{{ block.settings.line_icon }}</span>
            {% endif %}
            <span>{{ block.settings.line_text }}</span>
          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>

  {% comment %} BOTTOM: Horizontal Footer Menu List (Privacy, Terms etc) - NO DIVIDER {% endcomment %}
  {% if section.settings.footer_menu != blank %}
    {% assign footer_nav = linklists[section.settings.footer_menu] %}
    {% if footer_nav.links.size > 0 %}
      <div class="custom-footer__menu-bar">
        <ul class="custom-footer__menu-list">
          {% for link in footer_nav.links %}
            <li class="custom-footer__menu-item">
              <a href="{{ link.url }}" class="custom-footer__menu-link">{{ link.title }}</a>
            </li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}
  {% endif %}

</footer>

<style>
  .custom-footer {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    width: 100%;
  }

  .custom-footer__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center; /* Vertically align items */
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }

  /* ── LEFT: Brand ── */
  .custom-footer__brand {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
    min-width: 160px;
  }

  .custom-footer__logo-img {
    display: block;
    height: auto;
    width: 100%; /* controlled by max-width inline */
  }

  .custom-footer__copyright {
    color: {{ section.settings.text_color }};
    font-size: 13px;
    margin: 0;
    opacity: 0.75;
  }

  /* ── CENTER ── */
  .custom-footer__center {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
  }

  .custom-footer__badge {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custom-footer__badge-img {
    display: block;
    height: auto;
  }

  /* ── RIGHT: Contact ── */
  .custom-footer__contact {
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
    min-width: 200px;
    align-items: flex-end;
    text-align: right;
  }

  .custom-footer__contact-heading {
    color: {{ section.settings.text_color }};
    font-size: 15px;
    font-weight: 700;
    margin: 0 0 4px;
  }

  .custom-footer__contact-line {
    color: {{ section.settings.text_color }};
    font-size: 13px;
    margin: 0;
    line-height: 1.5;
    opacity: 0.9;
    display: flex;
    align-items: flex-start;
    gap: 6px;
    justify-content: flex-end;
  }

  /* ── BOTTOM Menu Bar (NO DIVIDER) ── */
  .custom-footer__menu-bar {
    max-width: {{ section.settings.max_width }}px;
    margin: 16px auto 0; /* Add top margin below main section */
    padding: 16px 24px 0;
    /* Removed top border divider */
  }

  .custom-footer__menu-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 24px; /* Gap between horizontal items */
  }

  .custom-footer__menu-link {
    color: {{ section.settings.text_color }};
    font-size: 13px;
    text-decoration: none;
    opacity: 0.75;
    transition: opacity 0.2s ease;
  }

  .custom-footer__menu-link:hover {
    opacity: 1;
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .custom-footer__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }
    .custom-footer__contact {
      align-items: flex-start;
      text-align: left;
    }
    .custom-footer__contact-line {
      justify-content: flex-start;
    }
    .custom-footer__center {
        justify-content: flex-start;
    }
     .custom-footer__menu-list {
        gap: 8px 16px;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 60,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 140
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "WeightRx"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "© [year] WeightRx"
    },
    {
      "type": "header",
      "content": "Center Image (e.g., Badge)"
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Center image"
    },
    {
      "type": "range",
      "id": "center_image_width",
      "label": "Center image width",
      "min": 40,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 90
    },
    {
      "type": "text",
      "id": "center_image_alt",
      "label": "Image alt text",
      "default": "Certified Badge"
    },
    {
      "type": "url",
      "id": "center_image_link",
      "label": "Image link (optional)"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact heading",
      "default": "Contact Care Team"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Bottom Horizontal Menu",
      "info": "Select menu for Privacy, Terms etc."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1A237E"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Max width (px)",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "contact_line",
      "name": "Contact line",
      "settings": [
        {
          "type": "text",
          "id": "line_icon",
          "label": "Icon (optional)"
        },
        {
          "type": "text",
          "id": "line_text",
          "label": "Line text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Footer"
    }
  ]
}
{% endschema %}