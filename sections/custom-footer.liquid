<footer class="custom-footer">
  <div class="custom-footer__inner">

    {% comment %} LEFT: Logo + Copyright {% endcomment %}
    <div class="custom-footer__brand">
      {% if section.settings.logo != blank %}
        <a href="{{ routes.root_url }}" class="custom-footer__logo-link">
          <img
            src="{{ section.settings.logo | image_url: width: 300 }}"
            alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
            width="{{ section.settings.logo_width }}"
            class="custom-footer__logo-img"
            loading="lazy"
            style="max-width: {{ section.settings.logo_width }}px;"
          >
        </a>
      {% else %}
        <a href="{{ routes.root_url }}" class="custom-footer__logo-text">
          {{ section.settings.brand_name | default: shop.name }}
        </a>
      {% endif %}

      <p class="custom-footer__copyright">
        {% if section.settings.copyright_text != blank %}
          {{ section.settings.copyright_text | replace: '[year]', 'now' | date: '%Y' }}
        {% else %}
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
        {% endif %}
      </p>
    </div>

    {% comment %} RIGHT: Contact Info + Menu Links {% endcomment %}
    <div class="custom-footer__right-content">
      {% if section.settings.contact_heading != blank %}
        <p class="custom-footer__contact-heading">{{ section.settings.contact_heading }}</p>
      {% endif %}

      {% comment %} Contact Details Blocks {% endcomment %}
      <div class="custom-footer__contact-info">
        {% for block in section.blocks %}
          {% if block.type == 'contact_line' %}
            <div class="custom-footer__contact-line" {{ block.shopify_attributes }}>
              {% if block.settings.line_icon != blank %}
                <span class="custom-footer__contact-icon">{{ block.settings.line_icon }}</span>
              {% endif %}
              <span>{{ block.settings.line_text }}</span>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% comment %} Right Side Menu (Terms, Privacy etc) {% endcomment %}
      {% if section.settings.footer_menu != blank %}
        {% assign footer_nav = linklists[section.settings.footer_menu] %}
        {% if footer_nav.links.size > 0 %}
          <div class="custom-footer__right-menu">
            {% for link in footer_nav.links %}
              <a href="{{ link.url }}" class="custom-footer__right-link">{{ link.title }}</a>
            {% endfor %}
          </div>
        {% endif %}
      {% endif %}
    </div>

  </div>
</footer>

<style>
  .custom-footer {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    width: 100%;
  }

  .custom-footer__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 40px;
    flex-wrap: wrap;
  }

  /* ── LEFT SIDE ── */
  .custom-footer__brand {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
    min-width: 200px;
  }

  .custom-footer__logo-img {
    display: block;
    height: auto;
    width: 100%;
  }

  .custom-footer__copyright {
    color: {{ section.settings.text_color }};
    font-size: 13px;
    margin: 0;
    opacity: 0.7;
  }

  /* ── RIGHT SIDE ── */
  .custom-footer__right-content {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
    min-width: 300px;
    align-items: flex-end;
    text-align: right;
  }

  .custom-footer__contact-heading {
    color: {{ section.settings.text_color }};
    font-size: 16px;
    font-weight: 700;
    margin: 0;
  }

  .custom-footer__contact-info {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 8px;
  }

  .custom-footer__contact-line {
    color: {{ section.settings.text_color }};
    font-size: 13px;
    opacity: 0.9;
    display: flex;
    align-items: flex-start;
    gap: 8px;
    justify-content: flex-end;
    line-height: 1.4;
  }

  /* Right Menu Links Styling */
  .custom-footer__right-menu {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    justify-content: flex-end;
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .custom-footer__right-link {
    color: {{ section.settings.text_color }};
    font-size: 12px;
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .custom-footer__right-link:hover {
    opacity: 1;
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .custom-footer__inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .custom-footer__right-content, 
    .custom-footer__contact-line,
    .custom-footer__right-menu {
      align-items: center;
      text-align: center;
      justify-content: center;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 50,
      "max": 250,
      "step": 5,
      "unit": "px",
      "default": 120
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "WeightRx"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "© [year] WeightRx"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact heading",
      "default": "Contact Care Team"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Right Side Menu",
      "info": "Select menu for Privacy, Terms etc."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1A237E"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Max width (px)",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "contact_line",
      "name": "Contact line",
      "settings": [
        {
          "type": "text",
          "id": "line_icon",
          "label": "Icon (optional)"
        },
        {
          "type": "text",
          "id": "line_text",
          "label": "Line text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Footer"
    }
  ]
}
{% endschema %}