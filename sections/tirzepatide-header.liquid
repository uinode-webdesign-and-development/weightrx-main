{{ 'landing-page.css' | asset_url | stylesheet_tag: preload: true }}

{%- style -%}
  .timer-section-{{ section.id }} .timer-display {
    text-decoration: underline;
    margin-left: 5px;
  }
{%- endstyle -%}

<div class="timer-section-{{ section.id }}">
  <div class="sale-banner">
    {{ section.settings.message_text }}
    <span id="countdown" class="timer-display">Loading...</span>
  </div>
</div>

<script>
  function startCountdown() {
    const baseEndDate = new Date('2026-02-26T01:59:30').getTime();
    const extensionDays = 3; // change to 6 if you want 6-day extensions
    const extensionMs = extensionDays * 24 * 60 * 60 * 1000;
    const countdownEl = document.getElementById('countdown');

    function getNextEndDate(now) {
      if (now < baseEndDate) return baseEndDate;

      const timePassed = now - baseEndDate;
      const extensionsNeeded = Math.floor(timePassed / extensionMs) + 1;
      return baseEndDate + extensionsNeeded * extensionMs;
    }

    function updateTimer() {
      const now = Date.now();
      const nextEndDate = getNextEndDate(now);
      const diff = nextEndDate - now;

      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
      const mins = Math.floor((diff / (1000 * 60)) % 60);
      const secs = Math.floor((diff / 1000) % 60);

      countdownEl.textContent = `${days} Days ${hours} Hours ${mins} mins ${secs} secs`;
    }

    updateTimer();
    setInterval(updateTimer, 1000);
  }

  startCountdown();
</script>

{%- liquid
  capture logo
    content_for 'block', type: '_header-logo', id: 'header-logo'
  endcapture
-%}

<div class="header-container">
  <div class="header-content">
    <nav class="nav">
      <div>
        {{ logo }}
      </div>
      {% if section.settings.custom_button_1_url or section.settings.custom_button_1_label %}
        <div class="nav-buttons">
          <a class="sign-in-btn" href="{{ section.settings.custom_button_1_url }}">
            {{- section.settings.custom_button_1_label -}}
          </a>
          <a class="quiz-btn desktop-quiz-btn js-quiz-link" href="{{ section.settings.custom_button_2_url }}">
            {{ section.settings.custom_button_2_label }}
            {% comment %} {%- render 'icon', icon: 'caret' -%} {% endcomment %}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </a>
        </div>
      {% endif %}
    </nav>
  </div>
</div>

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if settings.logo %}
      "logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
    {% endif %}
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

{% schema %}
{
  "name": "Tirzepatide Header",
  "settings": [
    {
      "type": "header",
      "content": "Announcement Bar"
    },
    {
      "type": "text",
      "id": "message_text",
      "label": "Announcement Text",
      "default": "🔥 Limited Time Offer - Ending In:"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "End Date (Format: May 1, 2026 23:59:59)",
      "info": "Month Day, Year HH:MM:SS",
      "default": "May 1, 2026 23:59:59"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ff0000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 14
    },
    {
      "type": "header",
      "content": "Tirzepatide Header Content"
    },
    {
      "type": "header",
      "content": "t:content.custom_buttons"
    },
    {
      "type": "text",
      "id": "custom_button_1_label",
      "label": "t:settings.button_label_primary",
      "default": "Sign In"
    },
    {
      "type": "url",
      "id": "custom_button_1_url",
      "label": "t:settings.button_url"
    },
    {
      "type": "text",
      "id": "custom_button_2_label",
      "label": "t:settings.button_label_secondary",
      "default": "Get Started Now"
    },
    {
      "type": "url",
      "id": "custom_button_2_url",
      "label": "t:settings.button_url"
    }
  ],
  "presets": [
    {
      "name": "Custom Announcement Bar"
    }
  ]
}
{% endschema %}
