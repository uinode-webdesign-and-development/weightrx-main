{% doc %}
  @prompt
    Create a two column section where one column will take heading, subheading and paragraph text. In second column we can upload 4 images with different heights and links where we can link and upload images.
    Section will have a background color field and adjust able padding.  , images should be side by side. Two column images one image above and other at bottom. And total 4 images 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-two-column-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_horizontal }}px;
    padding-right: {{ block.settings.padding_horizontal }}px;
  }

  .ai-two-column-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.column_gap }}px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-two-column-text-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_spacing }}px;
    justify-content: center;
  }

  .ai-two-column-heading-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-two-column-subheading-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
  }

  .ai-two-column-paragraph-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.paragraph_color }};
    font-size: {{ block.settings.paragraph_size }}px;
    line-height: 1.6;
  }

  .ai-two-column-images-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.image_gap }}px;
  }

  .ai-two-column-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-two-column-image-wrapper-{{ ai_gen_id }}:nth-child(1) {
    grid-column: 1;
    grid-row: 1;
  }

  .ai-two-column-image-wrapper-{{ ai_gen_id }}:nth-child(2) {
    grid-column: 1;
    grid-row: 2;
  }

  .ai-two-column-image-wrapper-{{ ai_gen_id }}:nth-child(3) {
    grid-column: 2;
    grid-row: 1;
  }

  .ai-two-column-image-wrapper-{{ ai_gen_id }}:nth-child(4) {
    grid-column: 2;
    grid-row: 2;
  }

  .ai-two-column-image-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
  }

  .ai-two-column-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-two-column-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 200px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-two-column-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  @media screen and (max-width: 749px) {
    .ai-two-column-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-two-column-images-{{ ai_gen_id }} {
      grid-template-columns: 1fr 1fr;
    }

    .ai-two-column-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-two-column-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.8);
    }

    .ai-two-column-paragraph-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.paragraph_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-two-column-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-two-column-container-{{ ai_gen_id }}">
    <div class="ai-two-column-text-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-two-column-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <h3 class="ai-two-column-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</h3>
      {% endif %}

      {% if block.settings.paragraph != blank %}
        <div class="ai-two-column-paragraph-{{ ai_gen_id }}">{{ block.settings.paragraph }}</div>
      {% endif %}
    </div>

    <div class="ai-two-column-images-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign link_key = 'image_' | append: i | append: '_link'
          assign image = block.settings[image_key]
          assign link = block.settings[link_key]
        %}

        <div class="ai-two-column-image-wrapper-{{ ai_gen_id }}">
          {% if link != blank %}
            <a href="{{ link }}" class="ai-two-column-image-link-{{ ai_gen_id }}">
          {% endif %}

          {% if image != blank %}
            <img
              src="{{ image | image_url: width: 800 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
              class="ai-two-column-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-two-column-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}

          {% if link != blank %}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

