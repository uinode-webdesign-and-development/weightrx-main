  <script>
    const disclaimerButton = document.querySelector(".disclaimer-button");
    const hiddenText = document.querySelector(".disclaimer-hidden");

    disclaimerButton.addEventListener("click", () => {
      hiddenText.classList.toggle("active");

      disclaimerButton.textContent = hiddenText.classList.contains("active")
        ? "See Less"
        : "See More";
    });
  </script>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const maxHeight = 140; // px
      const quoteContainers = document.querySelectorAll(
        ".customer-feedback__quote-text"
      );

      quoteContainers.forEach((container) => {
        const span = container.querySelector("span");
        const btn = container.querySelector(".customer-feedback__read-more");

        if (!span || !btn) return;

        let isExpandable = false;
        let expanded = false;

        // Check if text is longer than 160px
        if (span.scrollHeight > maxHeight) {
          isExpandable = true;

          span.style.display = "block";
          span.style.maxHeight = maxHeight + "px";
          span.style.overflow = "hidden";

          btn.textContent = "Read More";
        } else {
          // Short text â†’ no collapse
          span.style.maxHeight = "none";
          btn.textContent = "Read More"; // always visible
        }

        // Button click
        btn.addEventListener("click", () => {
          if (!isExpandable) return; // short text â†’ no action

          if (expanded) {
            span.style.maxHeight = maxHeight + "px";
            btn.textContent = "Read More";
          } else {
            span.style.maxHeight = span.scrollHeight + "px";
            btn.textContent = "Read Less";
          }

          expanded = !expanded;
        });
      });
    });
  </script>
